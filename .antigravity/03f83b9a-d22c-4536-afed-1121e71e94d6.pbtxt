    instruction: "Configure database initialization to load and parse tcx files from a dedicated ./tcx directory, seeding it with sample tcx files if empty."
    replacement_infos {
      original_chunk {
        target_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport fs from \'fs\';\nimport path from \'path\';\nimport { Activity, ChatMessage } from \'../src/types.js\';\n\nconst DATA_DIR = path.join(process.cwd(), \'data\');\nconst ACTIVITIES_FILE = path.join(DATA_DIR, \'activities.json\');\nconst CHAT_HISTORY_FILE = path.join(DATA_DIR, \'chat_history.json\');\nconst TRAINING_PLANS_FILE = path.join(DATA_DIR, \'training_plans.json\');\n\n// Helper to ensure directory and files exist\nexport async function initializeDb() {\n  try {\n    if (!fs.existsSync(DATA_DIR)) {\n      fs.mkdirSync(DATA_DIR, { recursive: true });\n    }\n\n    // Default Activities\n    if (!fs.existsSync(ACTIVITIES_FILE)) {\n      const defaultActivities: Activity[] = [\n        {\n          id: \'act_1\',\n          sport: \'Running\',\n          name: \'Lungo del Weekend - Parco e Naviglio\',\n          date: new Date(Date.now() - 2 * 24 * 60 * 60 * 1000).toISOString(), // 2 days ago\n          distanceKm: 15.2,\n          durationMin: 81,\n          calories: 1040,\n          avgHeartRate: 142,\n          maxHeartRate: 158,\n          avgCadence: 178,\n          maxCadence: 184,\n          avgSpeedKmh: 11.26,\n          maxSpeedKmh: 13.5,\n          avgPace: \'05:19\',\n          deviceBrand: \'Garmin\',\n          deviceModel: \'Forerunner 955\',\n          notes: \'Sensazioni ottime. Ritmo costante per tutti i 15km. Clima fresco ideale, circa 18\302\260C. Battiti stabili sotto la soglia aerobica.\',\n          laps: [\n            { lapIndex: 1, distanceKm: 5.0, durationSec: 1620, calories: 340, avgHeartRate: 138, maxHeartRate: 144, avgCadence: 176 },\n            { lapIndex: 2, distanceKm: 5.0, durationSec: 1590, calories: 350, avgHeartRate: 142, maxHeartRate: 148, avgCadence: 178 },\n            { lapIndex: 3, distanceKm: 5.2, durationSec: 1650, calories: 350, avgHeartRate: 146, maxHeartRate: 158, avgCadence: 180 }\n          ]\n        },\n        {\n          id: \'act_2\',\n          sport: \'Running\',\n          name: \'Ripetute in Salita 6x200m\',\n          date: new Date(Date.now() - 4 * 24 * 60 * 60 * 1000).toISOString(), // 4 days ago\n          distanceKm: 7.5,\n          durationMin: 44,\n          calories: 580,\n          avgHeartRate: 154,\n          maxHeartRate: 176,\n          avgCadence: 182,\n          maxCadence: 194,\n          avgSpeedKmh: 10.23,\n          maxSpeedKmh: 18.2,\n          avgPace: \'05:52\',\n          deviceBrand: \'Garmin\',\n          deviceModel: \'Forerunner 955\',\n          notes: \'Riscaldamento di 3km, poi 6 salite da 200m corse al massimo con recupero camminando in discesa. Defaticamento finale. Ottimo lavoro di forza.\',\n          laps: [\n            { lapIndex: 1, distanceKm: 3.0, durationSec: 1020, calories: 230, avgHeartRate: 135, maxHeartRate: 145, avgCadence: 174 },\n            { lapIndex: 2, distanceKm: 2.0, durationSec: 720, calories: 180, avgHeartRate: 168, maxHeartRate: 176, avgCadence: 188 },\n            { lapIndex: 3, distanceKm: 2.5, durationSec: 900, calories: 170, avgHeartRate: 144, maxHeartRate: 155, avgCadence: 176 }\n          ]\n        },\n        {\n          id: \'act_3\',\n          sport: \'Running\',\n          name: \'Corsa Media Progressiva\',\n          date: new Date(Date.now() - 6 * 24 * 60 * 60 * 1000).toISOString(), // 6 days ago\n          distanceKm: 10.0,\n          durationMin: 51,\n          calories: 780,\n          avgHeartRate: 148,\n          maxHeartRate: 165,\n          avgCadence: 180,\n          maxCadence: 186,\n          avgSpeedKmh: 11.76,\n          maxSpeedKmh: 14.1,\n          avgPace: \'05:06\',\n          deviceBrand: \'Garmin\',\n          deviceModel: \'Forerunner 955\',\n          notes: \'Partito a 5:25/km, finito a 4:45/km. Progressione fluida senza forzare troppo. Gambe reattive fin dall\\\'inizio.\',\n          laps: [\n            { lapIndex: 1, distanceKm: 3.3, durationSec: 1060, calories: 250, avgHeartRate: 140, maxHeartRate: 148, avgCadence: 178 },\n            { lapIndex: 2, distanceKm: 3.3, durationSec: 1010, calories: 260, avgHeartRate: 150, maxHeartRate: 156, avgCadence: 180 },\n            { lapIndex: 3, distanceKm: 3.4, durationSec: 990, calories: 270, avgHeartRate: 154, maxHeartRate: 165, avgCadence: 182 }\n          ]\n        },\n        {\n          id: \'act_4\',\n          sport: \'Running\',\n          name: \'Corsa Lenta di Scarico\',\n          date: new Date(Date.now() - 8 * 24 * 60 * 60 * 1000).toISOString(), // 8 days ago\n          distanceKm: 6.0,\n          durationMin: 35,\n          calories: 450,\n          avgHeartRate: 132,\n          maxHeartRate: 141,\n          avgCadence: 175,\n          maxCadence: 178,\n          avgSpeedKmh: 10.28,\n          maxSpeedKmh: 11.2,\n          avgPace: \'05:50\',\n          deviceBrand: \'Garmin\',\n          deviceModel: \'Forerunner 955\',\n          notes: \'Ritmo blando dopo le ripetute del giorno prima. Clima caldo umido ma gestibile. Battiti bassi come pianificato.\',\n          laps: [\n            { lapIndex: 1, distanceKm: 6.0, durationSec: 2100, calories: 450, avgHeartRate: 132, maxHeartRate: 141, avgCadence: 175 }\n          ]\n        },\n        {\n          id: \'act_5\',\n          sport: \'Running\',\n          name: \'Ripetute Medie 4x1000m\',\n          date: new Date(Date.now() - 10 * 24 * 60 * 60 * 1000).toISOString(), // 10 days ago\n          distanceKm: 9.0,\n          durationMin: 47,\n          calories: 710,\n          avgHeartRate: 156,\n          maxHeartRate: 178,\n          avgCadence: 181,\n          maxCadence: 188,\n          avgSpeedKmh: 11.49,\n          maxSpeedKmh: 15.5,\n          avgPace: \'05:13\',\n          deviceBrand: \'Garmin\',\n          deviceModel: \'Forerunner 955\',\n          notes: \'Target 1000m a 4:30/km. Tempi effettivi: 4:28, 4:27, 4:31, 4:25. Sensazioni di fatica controllata, recupero di 2 minuti di corsa lenta tra le serie.\',\n          laps: [\n            { lapIndex: 1, distanceKm: 2.0, durationSec: 660, calories: 150, avgHeartRate: 135, maxHeartRate: 145, avgCadence: 176 },\n            { lapIndex: 2, distanceKm: 4.0, durationSec: 1080, calories: 320, avgHeartRate: 165, maxHeartRate: 178, avgCadence: 183 },\n            { lapIndex: 3, distanceKm: 3.0, durationSec: 1080, calories: 240, avgHeartRate: 144, maxHeartRate: 152, avgCadence: 176 }\n          ]\n        }\n      ];\n      fs.writeFileSync(ACTIVITIES_FILE, JSON.stringify(defaultActivities, null, 2));\n    }"
        replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport fs from \'fs\';\nimport path from \'path\';\nimport { Activity, ChatMessage } from \'../src/types.js\';\nimport { parseTcx } from \'./tcxParser.js\';\n\nconst DATA_DIR = path.join(process.cwd(), \'data\');\nconst ACTIVITIES_FILE = path.join(DATA_DIR, \'activities.json\');\nconst CHAT_HISTORY_FILE = path.join(DATA_DIR, \'chat_history.json\');\nconst TRAINING_PLANS_FILE = path.join(DATA_DIR, \'training_plans.json\');\nexport const TCX_DIR = path.join(process.cwd(), \'tcx\');\n\nconst SAMPLE_TCX_1 = `<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<TrainingCenterDatabase xmlns=\"http://www.garmin.com/xmlschemas/TrainingCenterDatabase/v2\">\n  <Activities>\n    <Activity Sport=\"Running\">\n      <Id>2026-07-12T08:30:00Z</Id>\n      <Lap StartTime=\"2026-07-12T08:30:00Z\">\n        <TotalTimeSeconds>1500</TotalTimeSeconds>\n        <DistanceMeters>5000</DistanceMeters>\n        <MaximumSpeed>3.8</MaximumSpeed>\n        <Calories>340</Calories>\n        <AverageHeartRateBpm><Value>138</Value></AverageHeartRateBpm>\n        <MaximumHeartRateBpm><Value>144</Value></MaximumHeartRateBpm>\n        <Cadence>88</Cadence>\n      </Lap>\n      <Lap StartTime=\"2026-07-12T08:55:00Z\">\n        <TotalTimeSeconds>1560</TotalTimeSeconds>\n        <DistanceMeters>5000</DistanceMeters>\n        <MaximumSpeed>3.9</MaximumSpeed>\n        <Calories>350</Calories>\n        <AverageHeartRateBpm><Value>142</Value></AverageHeartRateBpm>\n        <MaximumHeartRateBpm><Value>148</Value></MaximumHeartRateBpm>\n        <Cadence>89</Cadence>\n      </Lap>\n      <Creator>\n        <Name>Garmin Forerunner 955</Name>\n      </Creator>\n    </Activity>\n  </Activities>\n</TrainingCenterDatabase>`;\n\nconst SAMPLE_TCX_2 = `<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<TrainingCenterDatabase xmlns=\"http://www.garmin.com/xmlschemas/TrainingCenterDatabase/v2\">\n  <Activities>\n    <Activity Sport=\"Running\">\n      <Id>2026-07-10T18:15:00Z</Id>\n      <Lap StartTime=\"2026-07-10T18:15:00Z\">\n        <TotalTimeSeconds>1380</TotalTimeSeconds>\n        <DistanceMeters>4500</DistanceMeters>\n        <MaximumSpeed>4.5</MaximumSpeed>\n        <Calories>310</Calories>\n        <AverageHeartRateBpm><Value>145</Value></AverageHeartRateBpm>\n        <MaximumHeartRateBpm><Value>158</Value></MaximumHeartRateBpm>\n        <Cadence>90</Cadence>\n      </Lap>\n      <Lap StartTime=\"2026-07-10T18:38:00Z\">\n        <TotalTimeSeconds>1260</TotalTimeSeconds>\n        <DistanceMeters>4500</DistanceMeters>\n        <MaximumSpeed>5.1</MaximumSpeed>\n        <Calories>300</Calories>\n        <AverageHeartRateBpm><Value>152</Value></AverageHeartRateBpm>\n        <MaximumHeartRateBpm><Value>166</Value></MaximumHeartRateBpm>\n        <Cadence>91</Cadence>\n      </Lap>\n      <Creator>\n        <Name>Garmin Forerunner 955</Name>\n      </Creator>\n    </Activity>\n  </Activities>\n</TrainingCenterDatabase>`;\n\nconst SAMPLE_TCX_3 = `<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<TrainingCenterDatabase xmlns=\"http://www.garmin.com/xmlschemas/TrainingCenterDatabase/v2\">\n  <Activities>\n    <Activity Sport=\"Running\">\n      <Id>2026-07-07T07:00:00Z</Id>\n      <Lap StartTime=\"2026-07-07T07:00:00Z\">\n        <TotalTimeSeconds>4860</TotalTimeSeconds>\n        <DistanceMeters>15000</DistanceMeters>\n        <MaximumSpeed>3.7</MaximumSpeed>\n        <Calories>1020</Calories>\n        <AverageHeartRateBpm><Value>135</Value></AverageHeartRateBpm>\n        <MaximumHeartRateBpm><Value>142</Value></MaximumHeartRateBpm>\n        <Cadence>87</Cadence>\n      </Lap>\n      <Creator>\n        <Name>Strava App</Name>\n      </Creator>\n    </Activity>\n  </Activities>\n</TrainingCenterDatabase>`;\n\n// Helper to ensure directory and files exist\nexport async function initializeDb() {\n  try {\n    if (!fs.existsSync(DATA_DIR)) {\n      fs.mkdirSync(DATA_DIR, { recursive: true });\n    }\n\n    if (!fs.existsSync(TCX_DIR)) {\n      fs.mkdirSync(TCX_DIR, { recursive: true });\n    }\n\n    // Seed default TCX files if none exist in the folder\n    const files = fs.readdirSync(TCX_DIR).filter(f => f.endsWith(\'.tcx\') || f.endsWith(\'.TCX\'));\n    if (files.length === 0) {\n      fs.writeFileSync(path.join(TCX_DIR, \'lungo_del_weekend.tcx\'), SAMPLE_TCX_1);\n      fs.writeFileSync(path.join(TCX_DIR, \'ripetute_in_salita.tcx\'), SAMPLE_TCX_2);\n      fs.writeFileSync(path.join(TCX_DIR, \'corsa_progressiva.tcx\'), SAMPLE_TCX_3);\n    }\n\n    // Parse all files in the TCX folder and compile them into activities.json\n    const updatedFiles = fs.readdirSync(TCX_DIR).filter(f => f.endsWith(\'.tcx\') || f.endsWith(\'.TCX\'));\n    const parsedActivities: Activity[] = [];\n    \n    for (const file of updatedFiles) {\n      try {\n        const filePath = path.join(TCX_DIR, file);\n        const xmlContent = fs.readFileSync(filePath, \'utf8\');\n        if (xmlContent.includes(\'<TrainingCenterDatabase\')) {\n          const act = parseTcx(xmlContent);\n          // Set custom name if it was the generated one to match previous default style nicely\n          if (file === \'lungo_del_weekend.tcx\') act.name = \'Lungo del Weekend - Parco e Naviglio\';\n          if (file === \'ripetute_in_salita.tcx\') act.name = \'Ripetute in Salita 6x200m\';\n          if (file === \'corsa_progressiva.tcx\') act.name = \'Corsa Media Progressiva\';\n          parsedActivities.push(act);\n        }\n      } catch (err) {\n        console.error(`Error parsing file ${file}:`, err);\n      }\n    }\n\n    // Sort by date descending\n    parsedActivities.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());\n    fs.writeFileSync(ACTIVITIES_FILE, JSON.stringify(parsedActivities, null, 2));"
      }
      num_matches: 1
    }
  }
}
