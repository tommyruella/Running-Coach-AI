        }
        lines {
          text: "            {/* Custom SVG Responsive Chart */}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            <div className=\"h-64 w-full relative pt-4\" id=\"svg-trend-chart\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              {chartData.length === 0 ? ("
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                <div className=\"absolute inset-0 flex items-center justify-center text-slate-500 text-sm\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                  Nessun dato registrato. Carica un file TCX per visualizzare il grafico."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                </div>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              ) : ("
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                <svg className=\"w-full h-full overflow-visible\" viewBox=\"0 0 500 200\" preserveAspectRatio=\"none\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                  {/* Grid Lines */}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                  <line x1=\"0\" y1=\"30\" x2=\"500\" y2=\"30\" stroke=\"#1e293b\" strokeDasharray=\"3,3\" />"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                  <line x1=\"0\" y1=\"80\" x2=\"500\" y2=\"80\" stroke=\"#1e293b\" strokeDasharray=\"3,3\" />"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                  <line x1=\"0\" y1=\"130\" x2=\"500\" y2=\"130\" stroke=\"#1e293b\" strokeDasharray=\"3,3\" />"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                  <line x1=\"0\" y1=\"170\" x2=\"500\" y2=\"170\" stroke=\"#334155\" />"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                  {/* Render Distance Bars & Pace Line */}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                  {chartData.map((d, index) => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                    const step = 500 / 6;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                    const x = step * (index + 0.8);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                    // Bar calculations (distance)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                    const barHeight = (d.distanceKm / maxDistance) * 140;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                    const yBar = 170 - barHeight;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                    // Line calculations (pace)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                    const paceSecs = paceToSeconds(d.avgPace);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                    const normalizedPace = (paceSecs - minPaceSecs) / (maxPaceSecs - minPaceSecs || 1);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                    // inverse because lower pace (smaller seconds) is better/higher on the chart"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                    const yLine = 40 + (normalizedPace * 100);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                    return ("
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                      <g key={d.id} className=\"cursor-pointer\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                        {/* Interactive Bar */}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                        <motion.rect"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          x={x - 12}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          y={yBar}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          width=\"24\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          height={barHeight}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          rx=\"4\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          fill=\"url(#emerald-grad)\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          initial={{ scaleY: 0, originY: 1 }}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          animate={{ scaleY: 1 }}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          transition={{ delay: index * 0.1, duration: 0.5 }}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          onHoverStart={() => setHoveredIndex(index)}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          onHoverEnd={() => setHoveredIndex(null)}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          className=\"hover:opacity-90 transition-opacity\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                        />"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                        {/* Pace Dot */}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                        <circle"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          cx={x}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          cy={yLine}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          r=\"5\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          fill=\"#22d3ee\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
