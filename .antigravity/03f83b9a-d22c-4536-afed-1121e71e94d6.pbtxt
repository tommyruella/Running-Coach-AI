  file_change {
    absolute_path_uri: "file:///src/App.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React, { useState, useEffect } from \'react\';\nimport { motion, AnimatePresence } from \'motion/react\';\nimport {\n  Activity,\n  Calendar,\n  MessageSquare,\n  Trophy,\n  Cpu,\n  Zap,\n  TrendingUp,\n  Flame,\n  Clock,\n  Heart\n} from \'lucide-react\';\nimport { Activity as ActivityType, ChatMessage, RunningStats } from \'./types.js\';\nimport Dashboard from \'./components/Dashboard.tsx\';\nimport Chat from \'./components/Chat.tsx\';\nimport History from \'./components/History.tsx\';\n\nexport default function App() {\n  const [activeTab, setActiveTab] = useState<\'chat\' | \'dashboard\' | \'history\'>(\'chat\');\n  const [activities, setActivities] = useState<ActivityType[]>([]);\n  const [chatHistory, setChatHistory] = useState<ChatMessage[]>([]);\n  const [stats, setStats] = useState<RunningStats>({\n    totalActivities: 0,\n    totalKm: 0,\n    totalDurationHours: 0,\n    avgPace: \'--:--\',\n    avgHr: 0\n  });\n\n  const [isSending, setIsSending] = useState(false);\n  const [isUploading, setIsUploading] = useState(false);\n  const [uploadError, setUploadError] = useState<string | null>(null);\n  const [uploadSuccess, setUploadSuccess] = useState<string | null>(null);\n\n  // Initial Fetch on load\n  const fetchData = async () => {\n    try {\n      // 1. Fetch Stats\n      const statsRes = await fetch(\'/api/stats\');\n      if (statsRes.ok) {\n        const statsData = await statsRes.json();\n        setStats(statsData);\n      }\n\n      // 2. Fetch Activities\n      const actRes = await fetch(\'/api/activities?limit=100\');\n      if (actRes.ok) {\n        const actData = await actRes.json();\n        setActivities(actData.activities);\n      }\n\n      // 3. Fetch Chat History\n      const chatRes = await fetch(\'/api/chat-history\');\n      if (chatRes.ok) {\n        const chatData = await chatRes.json();\n        setChatHistory(chatData.history);\n      }\n    } catch (error) {\n      console.error(\'Error loading full-stack coach data:\', error);\n    }\n  };\n\n  useEffect(() => {\n    fetchData();\n  }, []);\n\n  // Chat Submission Handler\n  const handleSendMessage = async (message: string, forcePremium: boolean) => {\n    setIsSending(true);\n    try {\n      const response = await fetch(\'/api/chat\', {\n        method: \'POST\',\n        headers: { \'Content-Type\': \'application/json\' },\n        body: JSON.stringify({ message, forcePremium })\n      });\n\n      if (response.ok) {\n        const result = await response.json();\n        // Update history in-state to render immediately\n        setChatHistory(prev => [...prev, result.user_message, result.assistant_response]);\n        \n        // If a plan was generated, let\'s refresh the data so it updates overall training plans\n        if (result.is_plan) {\n          fetchData();\n        }\n      } else {\n        const errorData = await response.json();\n        console.error(\'Chat error output:\', errorData);\n      }\n    } catch (error) {\n      console.error(\'Network error during chat submission:\', error);\n    } finally {\n      setIsSending(false);\n    }\n  };\n\n  // Clear Chat Handler\n  const handleClearChatHistory = async () => {\n    try {\n      const response = await fetch(\'/api/chat-clear\', { method: \'POST\' });\n      if (response.ok) {\n        setChatHistory([\n          {\n            id: \'chat_init\',\n            sender: \'assistant\',\n            text: `Ciao, Runner! \360\237\217\203\\n\\nBenvenuto sul tuo **Running Coach AI**. Sono qui per aiutarti a migliorare la tua forma fisica, strutturare le tue sessioni di allenamento ed analizzare le tue statistiche di corsa.\\n\\nEcco cosa posso fare per te:\\n1. **Analisi veloce (Groq)**: Chiedimi pareri sulle tue metriche di corsa, consigli di postura, scarpe o nutrizione.\\n2. **Programma Settimanale (Premium)**: Chiedimi di creare un piano di allenamento personalizzato scrivendo formule tipo \"*crea un piano per una maratona*\" o \"*preparami una settimana ad alta intensit\303\240*\". L\'AI Premium elaborer\303\240 per te un piano strutturato dettagliato.\\n3. **Analisi TCX**: Carica i file delle tue sessioni Garmin o Strava (.tcx) nella sezione **History** per popolare automaticamente il tuo grafico e le tue statistiche personali!\\n\\nCome posso aiutarti oggi?`,\n            timestamp: new Date().toISOString()\n          }\n        ]);\n      }\n    } catch (error) {\n      console.error(\'Error clearing chat:\', error);\n    }\n  };\n\n  // TCX File Upload Handler\n  const handleUploadTcx = async (file: File) => {\n    setIsUploading(true);\n    setUploadError(null);\n    setUploadSuccess(null);\n\n    const formData = new FormData();\n    formData.append(\'file\', file);\n\n    try {\n      const response = await fetch(\'/api/upload-tcx\', {\n        method: \'POST\',\n        body: formData\n      });\n\n      if (response.ok) {\n        const result = await response.json();\n        setUploadSuccess(`Successo! Sincronizzata corsa: \"${result.activity.name}\" (${result.activity.distanceKm} km)`);\n        \n        // Refresh local cache & database stats\n        await fetchData();\n        \n        // Auto-clear success message after 4 seconds\n        setTimeout(() => setUploadSuccess(null), 4000);\n      } else {\n        const errorResult = await response.json();\n        setUploadError(errorResult.error || \'Impossibile analizzare il file TCX.\');\n      }\n    } catch (error: any) {\n      setUploadError(`Errore di rete: ${error.message || \'Verifica la connessione.\'}`);\n    } finally {\n      setIsUploading(false);\n    }\n  };\n\n  return (\n    <div className=\"min-h-screen bg-slate-950 text-slate-100 flex flex-col font-sans\" id=\"app-root-container\">\n      \n      {/* Premium Dark Top Navigation Header */}\n      <header className=\"bg-slate-900/90 border-b border-slate-800/80 sticky top-0 z-40 backdrop-blur-md\">\n        <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between\">\n          \n          {/* Logo & Brand Identity */}\n          <div className=\"flex items-center gap-3\">\n            <div className=\"h-9 w-9 rounded-xl bg-emerald-500 text-slate-950 flex items-center justify-center shadow-lg shadow-emerald-500/10\">\n              <Activity className=\"h-5 w-5\" />\n            </div>\n            <div>\n              <h1 className=\"text-sm font-black text-white uppercase tracking-wider flex items-center gap-1.5\">\n                Running Coach <span className=\"text-emerald-400 font-mono text-xs\">AI</span>\n              </h1>\n              <p className=\"text-[10px] text-slate-400 font-medium\">Powering Serious Runners</p>\n            </div>\n          </div>\n\n          {/* Tab Navigation Menu */}\n          <nav className=\"flex bg-slate-950 p-1 rounded-xl border border-slate-800/80\">\n            <button\n              onClick={() => setActiveTab(\'chat\')}\n              className={`flex items-center gap-2 px-3 sm:px-4 py-1.5 rounded-lg text-xs font-bold transition-all duration-200 cursor-pointer ${\n                activeTab === \'chat\'\n                  ? \'bg-emerald-500 text-slate-950 shadow-md shadow-emerald-500/5\'\n                  : \'text-slate-400 hover:text-slate-200\'\n              }`}\n              id=\"nav-chat-tab\"\n            >\n              <MessageSquare className=\"h-4 w-4\" />\n              Chat AI\n            </button>\n            <button\n              onClick={() => setActiveTab(\'dashboard\')}\n              className={`flex items-center gap-2 px-3 sm:px-4 py-1.5 rounded-lg text-xs font-bold transition-all duration-200 cursor-pointer ${\n                activeTab === \'dashboard\'\n                  ? \'bg-emerald-500 text-slate-950 shadow-md shadow-emerald-500/5\'\n                  : \'text-slate-400 hover:text-slate-200\'\n              }`}\n              id=\"nav-dashboard-tab\"\n            >\n              <TrendingUp className=\"h-4 w-4\" />\n              Dashboard\n            </button>\n            <button\n              onClick={() => setActiveTab(\'history\')}\n              className={`flex items-center gap-2 px-3 sm:px-4 py-1.5 rounded-lg text-xs font-bold transition-all duration-200 cursor-pointer ${\n                activeTab === \'history\'\n                  ? \'bg-emerald-500 text-slate-950 shadow-md shadow-emerald-500/5\'\n                  : \'text-slate-400 hover:text-slate-200\'\n              }`}\n              id=\"nav-history-tab\"\n            >\n              <Calendar className=\"h-4 w-4\" />\n              Storico\n            </button>\n          </nav>\n\n        </div>\n      </header>\n\n      {/* Main Content Body */}\n      <main className=\"flex-1 max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8\">\n        <AnimatePresence mode=\"wait\">\n          {activeTab === \'chat\' && (\n            <motion.div\n              key=\"chat\"\n              initial={{ opacity: 0, y: 15 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, y: -15 }}\n              transition={{ duration: 0.2 }}\n            >\n              <Chat\n                chatHistory={chatHistory}\n                onSendMessage={handleSendMessage}\n                onClearHistory={handleClearChatHistory}\n                isSending={isSending}\n              />\n            </motion.div>\n          )}\n\n          {activeTab === \'dashboard\' && (\n            <motion.div\n              key=\"dashboard\"\n              initial={{ opacity: 0, y: 15 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, y: -15 }}\n              transition={{ duration: 0.2 }}\n            >\n              <Dashboard\n                stats={stats}\n                activities={activities}\n                onNavigateToHistory={() => setActiveTab(\'history\')}\n              />\n            </motion.div>\n          )}\n\n          {activeTab === \'history\' && (\n            <motion.div\n              key=\"history\"\n              initial={{ opacity: 0, y: 15 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, y: -15 }}\n              transition={{ duration: 0.2 }}\n            >\n              <History\n                activities={activities}\n                onUploadTcx={handleUploadTcx}\n                isUploading={isUploading}\n                uploadError={uploadError}\n                uploadSuccess={uploadSuccess}\n              />\n            </motion.div>\n          )}\n        </AnimatePresence>\n      </main>\n\n      {/* Aesthetic Architectural Footer */}\n      <footer className=\"bg-slate-950 border-t border-slate-900 py-6 text-center text-[10px] text-slate-500\">\n        <div className=\"max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-3\">\n          <p>Running Coach AI \302\251 2026 \342\200\242 Creato per runner esigenti.</p>\n          <div className=\"flex gap-4 font-mono\">\n            <span>Servizio LLM: Attivo</span>\n            <span>Parser TCX: Pronto</span>\n            <span>Archivio: Sincronizzato</span>\n          </div>\n        </div>\n      </footer>\n\n    </div>\n  );\n}\n"
    }
