  file_change {
    absolute_path_uri: "file:///src/components/Dashboard.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React from \'react\';\nimport { Activity, Calendar, Clock, Heart, Zap, ChevronRight } from \'lucide-react\';\nimport { Activity as ActivityType, RunningStats } from \'../types.js\';\n\ninterface DashboardProps {\n  stats: RunningStats;\n  activities: ActivityType[];\n  onNavigateToHistory: () => void;\n}\n\nexport default function Dashboard({ stats, activities, onNavigateToHistory }: DashboardProps) {\n  // Last 5 activities for the trend chart\n  const chartData = [...activities]\n    .slice(0, 5)\n    .reverse();\n\n  const maxDistance = Math.max(...chartData.map(d => d.distanceKm), 5);\n\n  return (\n    <div className=\"space-y-8\" id=\"dashboard-tab\">\n      \n      {/* Clean Header */}\n      <div className=\"flex flex-col sm:flex-row justify-between sm:items-center gap-2 border-b border-zinc-800 pb-5\">\n        <div>\n          <h2 className=\"text-xl font-semibold text-white tracking-tight\">Panoramica Allenamenti</h2>\n          <p className=\"text-xs text-zinc-500 mt-1\">\n            Analisi semplice e lineare dei tuoi dati di corsa sincronizzati.\n          </p>\n        </div>\n        <div className=\"text-[11px] bg-zinc-950 text-zinc-400 border border-zinc-800 rounded px-2.5 py-1 self-start sm:self-auto font-mono\">\n          TCX Folder Sync: Attivo\n        </div>\n      </div>\n\n      {/* Modern Minimal Stats Grid */}\n      <div className=\"grid grid-cols-2 md:grid-cols-5 gap-4\">\n        \n        {/* Distanza */}\n        <div className=\"bg-zinc-900 border border-zinc-800/80 p-5 rounded-lg flex flex-col justify-between h-28 hover:border-zinc-700 transition-colors\">\n          <div className=\"flex items-center justify-between text-zinc-500\">\n            <span className=\"text-xs font-medium tracking-tight\">Distanza</span>\n            <Zap className=\"h-4 w-4 text-lime-400\" />\n          </div>\n          <div>\n            <span className=\"text-2xl font-semibold font-mono text-white tracking-tight\">{stats.totalKm}</span>\n            <span className=\"text-xs text-zinc-500 ml-1\">km</span>\n          </div>\n        </div>\n\n        {/* Tempo */}\n        <div className=\"bg-zinc-900 border border-zinc-800/80 p-5 rounded-lg flex flex-col justify-between h-28 hover:border-zinc-700 transition-colors\">\n          <div className=\"flex items-center justify-between text-zinc-500\">\n            <span className=\"text-xs font-medium tracking-tight\">Tempo Totale</span>\n            <Clock className=\"h-4 w-4 text-zinc-400\" />\n          </div>\n          <div>\n            <span className=\"text-2xl font-semibold font-mono text-white tracking-tight\">{stats.totalDurationHours}</span>\n            <span className=\"text-xs text-zinc-500 ml-1\">ore</span>\n          </div>\n        </div>\n\n        {/* Passo Medio */}\n        <div className=\"bg-zinc-900 border border-zinc-800/80 p-5 rounded-lg flex flex-col justify-between h-28 hover:border-zinc-700 transition-colors\">\n          <div className=\"flex items-center justify-between text-zinc-500\">\n            <span className=\"text-xs font-medium tracking-tight\">Passo Medio</span>\n            <Activity className=\"h-4 w-4 text-cyan-400\" />\n          </div>\n          <div>\n            <span className=\"text-2xl font-semibold font-mono text-white tracking-tight\">{stats.avgPace}</span>\n            <span className=\"text-xs text-zinc-500 ml-1\">/km</span>\n          </div>\n        </div>\n\n        {/* Battito Medio */}\n        <div className=\"bg-zinc-900 border border-zinc-800/80 p-5 rounded-lg flex flex-col justify-between h-28 hover:border-zinc-700 transition-colors\">\n          <div className=\"flex items-center justify-between text-zinc-500\">\n            <span className=\"text-xs font-medium tracking-tight\">Battito Medio</span>\n            <Heart className=\"h-4 w-4 text-rose-500\" />\n          </div>\n          <div>\n            <span className=\"text-2xl font-semibold font-mono text-white tracking-tight\">{stats.avgHr || \'--\'}</span>\n            <span className=\"text-xs text-zinc-500 ml-1\">bpm</span>\n          </div>\n        </div>\n\n        {/* Sessioni */}\n        <div className=\"bg-zinc-900 border border-zinc-800/80 p-5 rounded-lg flex flex-col justify-between h-28 hover:border-zinc-700 transition-colors col-span-2 md:col-span-1\">\n          <div className=\"flex items-center justify-between text-zinc-500\">\n            <span className=\"text-xs font-medium tracking-tight\">Sessioni</span>\n            <Calendar className=\"h-4 w-4 text-zinc-400\" />\n          </div>\n          <div>\n            <span className=\"text-2xl font-semibold font-mono text-white tracking-tight\">{stats.totalActivities}</span>\n            <span className=\"text-xs text-zinc-500 ml-1\">corse</span>\n          </div>\n        </div>\n\n      </div>\n\n      {/* Main Layout: Minimal Chart & Recent Activities */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-6\">\n        \n        {/* Simplified Line Chart (7/12 width) */}\n        <div className=\"lg:col-span-7 bg-zinc-900 border border-zinc-800/80 rounded-lg p-5 flex flex-col justify-between\">\n          <div>\n            <div className=\"flex items-center justify-between mb-6 border-b border-zinc-800/50 pb-3\">\n              <div>\n                <h3 className=\"text-sm font-semibold text-white\">Trend Distanze</h3>\n                <p className=\"text-xs text-zinc-500 mt-0.5\">Le ultime 5 sessioni registrate nei file TCX</p>\n              </div>\n              <span className=\"text-[10px] font-mono text-zinc-400 bg-zinc-950 px-2 py-0.5 border border-zinc-800 rounded\">km per corsa</span>\n            </div>\n\n            {/* Custom Minimal SVG Chart */}\n            <div className=\"h-48 w-full relative pt-2\" id=\"svg-trend-chart\">\n              {chartData.length === 0 ? (\n                <div className=\"absolute inset-0 flex items-center justify-center text-zinc-500 text-xs font-mono uppercase\">\n                  Nessuna attivit\303\240 registrata nel database.\n                </div>\n              ) : (\n                <svg className=\"w-full h-full overflow-visible\" viewBox=\"0 0 500 160\" preserveAspectRatio=\"none\">\n                  {/* Subtle Grid Lines */}\n                  <line x1=\"0\" y1=\"20\" x2=\"500\" y2=\"20\" stroke=\"rgba(255,255,255,0.03)\" />\n                  <line x1=\"0\" y1=\"70\" x2=\"500\" y2=\"70\" stroke=\"rgba(255,255,255,0.03)\" />\n                  <line x1=\"0\" y1=\"120\" x2=\"500\" y2=\"120\" stroke=\"rgba(255,255,255,0.03)\" />\n                  <line x1=\"0\" y1=\"140\" x2=\"500\" y2=\"140\" stroke=\"rgba(255,255,255,0.08)\" />\n\n                  {/* Render Area Chart Path under the Line */}\n                  {chartData.length > 1 && (\n                    <path\n                      d={`\n                        M ${500 / 6 * 0.8} 140\n                        ${chartData.map((d, i) => {\n                          const x = (500 / 6) * (i + 0.8);\n                          const y = 140 - (d.distanceKm / maxDistance) * 100;\n                          return `L ${x} ${y}`;\n                        }).join(\' \')}\n                        L ${(500 / 6) * (chartData.length - 1 + 0.8)} 140\n                        Z\n                      `}\n                      fill=\"url(#area-glow)\"\n                      className=\"opacity-40\"\n                    />\n                  )}\n\n                  {/* Connected line between dots */}\n                  {chartData.length > 1 && (\n                    <path\n                      d={chartData.map((d, i) => {\n                        const x = (500 / 6) * (i + 0.8);\n                        const y = 140 - (d.distanceKm / maxDistance) * 100;\n                        return `${i === 0 ? \'M\' : \'L\'} ${x} ${y}`;\n                      }).join(\' \')}\n                      fill=\"none\"\n                      stroke=\"#CCFF00\"\n                      strokeWidth=\"2.5\"\n                    />\n                  )}\n\n                  {/* Render Dots and Labels */}\n                  {chartData.map((d, i) => {\n                    const x = (500 / 6) * (i + 0.8);\n                    const y = 140 - (d.distanceKm / maxDistance) * 100;\n\n                    return (\n                      <g key={d.id}>\n                        {/* Dot */}\n                        <circle\n                          cx={x}\n                          cy={y}\n                          r=\"5\"\n                          fill=\"#CCFF00\"\n                          stroke=\"#18181b\"\n                          strokeWidth=\"2\"\n                        />\n\n                        {/* Label Date */}\n                        <text\n                          x={x}\n                          y=\"156\"\n                          fill=\"#71717a\"\n                          fontSize=\"9\"\n                          textAnchor=\"middle\"\n                          fontFamily=\"sans-serif\"\n                        >\n                          {new Date(d.date).toLocaleDateString(\'it-IT\', { day: \'2-digit\', month: \'short\' })}\n                        </text>\n\n                        {/* Label value of Distance */}\n                        <text\n                          x={x}\n                          y={y - 10}\n                          fill=\"#ffffff\"\n                          fontSize=\"9\"\n                          fontWeight=\"600\"\n                          fontFamily=\"monospace\"\n                          textAnchor=\"middle\"\n                        >\n                          {d.distanceKm.toFixed(1)}\n                        </text>\n                      </g>\n                    );\n                  })}\n\n                  {/* Gradient definitions */}\n                  <defs>\n                    <linearGradient id=\"area-glow\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                      <stop offset=\"0%\" stopColor=\"#CCFF00\" stopOpacity=\"0.2\" />\n                      <stop offset=\"100%\" stopColor=\"#CCFF00\" stopOpacity=\"0.0\" />\n                    </linearGradient>\n                  </defs>\n                </svg>\n              )}\n            </div>\n          </div>\n          \n          <div className=\"mt-4 pt-3 border-t border-zinc-800/60 flex justify-between items-center text-xs text-zinc-500\">\n            <span>Aggiornato dai file TCX.</span>\n            <button \n              onClick={onNavigateToHistory}\n              className=\"text-lime-400 hover:text-white transition-colors flex items-center gap-0.5 font-medium\"\n            >\n              Vedi Storico Completo\n              <ChevronRight className=\"h-3.5 w-3.5\" />\n            </button>\n          </div>\n        </div>\n\n        {/* Recent runs list (5/12 width) */}\n        <div className=\"lg:col-span-5 bg-zinc-900 border border-zinc-800/80 rounded-lg p-5 flex flex-col justify-between\">\n          <div>\n            <h3 className=\"text-sm font-semibold text-white mb-4 border-b border-zinc-800/50 pb-3\">Attivit\303\240 Recenti</h3>\n            <div className=\"space-y-3\">\n              {activities.slice(0, 4).map((act) => (\n                <div \n                  key={act.id} \n                  className=\"bg-zinc-950 border border-zinc-800/50 p-3 rounded-lg flex items-center justify-between group hover:border-zinc-700 transition-colors cursor-pointer\"\n                  onClick={onNavigateToHistory}\n                >\n                  <div className=\"flex items-center gap-3\">\n                    <div className=\"h-9 w-9 bg-zinc-900 border border-zinc-800 text-lime-400 flex flex-col items-center justify-center font-mono font-bold text-xs rounded\">\n                      {act.distanceKm.toFixed(0)}\n                      <span className=\"text-[8px] font-normal uppercase -mt-1\">km</span>\n                    </div>\n                    <div className=\"min-w-0\">\n                      <h4 className=\"text-xs font-bold text-white truncate group-hover:text-lime-400 transition-colors\">\n                        {act.name}\n                      </h4>\n                      <p className=\"text-[10px] text-zinc-500 mt-0.5\">\n                        {new Date(act.date).toLocaleDateString(\'it-IT\', { day: \'numeric\', month: \'short\' })} \342\200\242 {act.durationMin} min\n                      </p>\n                    </div>\n                  </div>\n                  <div className=\"text-right font-mono text-xs\">\n                    <p className=\"font-bold text-white\">{act.avgPace}</p>\n                    <p className=\"text-[9px] text-zinc-500 mt-0.5\">/km</p>\n                  </div>\n                </div>\n              ))}\n\n              {activities.length === 0 && (\n                <div className=\"text-center py-10 text-zinc-500 text-xs\">\n                  Nessuna corsa registrata.\n                </div>\n              )}\n            </div>\n          </div>\n\n          <button \n            onClick={onNavigateToHistory}\n            className=\"w-full mt-4 bg-zinc-950 border border-zinc-800 hover:bg-zinc-950/80 text-zinc-400 hover:text-white text-xs font-medium py-2 rounded transition-colors flex items-center justify-center gap-1\"\n          >\n            Gestisci Attivit\303\240\n            <ChevronRight className=\"h-3.5 w-3.5\" />\n          </button>\n        </div>\n\n      </div>\n\n      {/* Simplified, Clean Advisory Block */}\n      <div className=\"bg-zinc-900 border border-zinc-800/80 p-5 rounded-lg flex items-start gap-4\">\n        <div className=\"p-2 bg-zinc-950 text-lime-400 rounded border border-zinc-800 shrink-0\">\n          <Activity className=\"h-5 w-5\" />\n        </div>\n        <div>\n          <h4 className=\"text-xs font-bold uppercase tracking-wider text-white\">Consiglio del Coach</h4>\n          <p className=\"text-xs text-zinc-400 mt-1 leading-relaxed max-w-4xl\">\n            In base alle sessioni sincronizzate dalla tua cartella, mantieni un ritmo regolare per ottimizzare la resistenza aerobica. Se il battito medio supera la soglia ideale ({stats.avgHr ? `${stats.avgHr} bpm` : \'--\'}), considera di inserire una sessione di scarico a ritmo lento.\n          </p>\n        </div>\n      </div>\n\n    </div>\n  );\n}\n"
    }
