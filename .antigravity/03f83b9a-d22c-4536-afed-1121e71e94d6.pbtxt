    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport fs from \'fs\';\nimport path from \'path\';\nimport { Activity, ChatMessage } from \'../src/types.js\';\n\nconst DATA_DIR = path.join(process.cwd(), \'data\');\nconst ACTIVITIES_FILE = path.join(DATA_DIR, \'activities.json\');\nconst CHAT_HISTORY_FILE = path.join(DATA_DIR, \'chat_history.json\');\nconst TRAINING_PLANS_FILE = path.join(DATA_DIR, \'training_plans.json\');\n\n// Helper to ensure directory and files exist\nexport async function initializeDb() {\n  try {\n    if (!fs.existsSync(DATA_DIR)) {\n      fs.mkdirSync(DATA_DIR, { recursive: true });\n    }\n\n    // Default Activities\n    if (!fs.existsSync(ACTIVITIES_FILE)) {\n      const defaultActivities: Activity[] = [\n        {\n          id: \'act_1\',\n          sport: \'Running\',\n          name: \'Lungo del Weekend - Parco e Naviglio\',\n          date: new Date(Date.now() - 2 * 24 * 60 * 60 * 1000).toISOString(), // 2 days ago\n          distanceKm: 15.2,\n          durationMin: 81,\n          calories: 1040,\n          avgHeartRate: 142,\n          maxHeartRate: 158,\n          avgCadence: 178,\n          maxCadence: 184,\n          avgSpeedKmh: 11.26,\n          maxSpeedKmh: 13.5,\n          avgPace: \'05:19\',\n          deviceBrand: \'Garmin\',\n          deviceModel: \'Forerunner 955\',\n          notes: \'Sensazioni ottime. Ritmo costante per tutti i 15km. Clima fresco ideale, circa 18\302\260C. Battiti stabili sotto la soglia aerobica.\',\n          laps: [\n            { lapIndex: 1, distanceKm: 5.0, durationSec: 1620, calories: 340, avgHeartRate: 138, maxHeartRate: 144, avgCadence: 176 },\n            { lapIndex: 2, distanceKm: 5.0, durationSec: 1590, calories: 350, avgHeartRate: 142, maxHeartRate: 148, avgCadence: 178 },\n            { lapIndex: 3, distanceKm: 5.2, durationSec: 1650, calories: 350, avgHeartRate: 146, maxHeartRate: 158, avgCadence: 180 }\n          ]\n        },\n        {\n          id: \'act_2\',\n          sport: \'Running\',\n          name: \'Ripetute in Salita 6x200m\',\n          date: new Date(Date.now() - 4 * 24 * 60 * 60 * 1000).toISOString(), // 4 days ago\n          distanceKm: 7.5,\n          durationMin: 44,\n          calories: 580,\n          avgHeartRate: 154,\n          maxHeartRate: 176,\n          avgCadence: 182,\n          maxCadence: 194,\n          avgSpeedKmh: 10.23,\n          maxSpeedKmh: 18.2,\n          avgPace: \'05:52\',\n          deviceBrand: \'Garmin\',\n          deviceModel: \'Forerunner 955\',\n          notes: \'Riscaldamento di 3km, poi 6 salite da 200m corse al massimo con recupero camminando in discesa. Defaticamento finale. Ottimo lavoro di forza.\',\n          laps: [\n            { lapIndex: 1, distanceKm: 3.0, durationSec: 1020, calories: 230, avgHeartRate: 135, maxHeartRate: 145, avgCadence: 174 },\n            { lapIndex: 2, distanceKm: 2.0, durationSec: 720, calories: 180, avgHeartRate: 168, maxHeartRate: 176, avgCadence: 188 },\n            { lapIndex: 3, distanceKm: 2.5, durationSec: 900, calories: 170, avgHeartRate: 144, maxHeartRate: 155, avgCadence: 176 }\n          ]\n        },\n        {\n          id: \'act_3\',\n          sport: \'Running\',\n          name: \'Corsa Media Progressiva\',\n          date: new Date(Date.now() - 6 * 24 * 60 * 60 * 1000).toISOString(), // 6 days ago\n          distanceKm: 10.0,\n          durationMin: 51,\n          calories: 780,\n          avgHeartRate: 148,\n          maxHeartRate: 165,\n          avgCadence: 180,\n          maxCadence: 186,\n          avgSpeedKmh: 11.76,\n          maxSpeedKmh: 14.1,\n          avgPace: \'05:06\',\n          deviceBrand: \'Garmin\',\n          deviceModel: \'Forerunner 955\',\n          notes: \'Partito a 5:25/km, finito a 4:45/km. Progressione fluida senza forzare troppo. Gambe reattive fin dall\\\'inizio.\',\n          laps: [\n            { lapIndex: 1, distanceKm: 3.3, durationSec: 1060, calories: 250, avgHeartRate: 140, maxHeartRate: 148, avgCadence: 178 },\n            { lapIndex: 2, distanceKm: 3.3, durationSec: 1010, calories: 260, avgHeartRate: 150, maxHeartRate: 156, avgCadence: 180 },\n            { lapIndex: 3, distanceKm: 3.4, durationSec: 990, calories: 270, avgHeartRate: 154, maxHeartRate: 165, avgCadence: 182 }\n          ]\n        },\n        {\n          id: \'act_4\',\n          sport: \'Running\',\n          name: \'Corsa Lenta di Scarico\',\n          date: new Date(Date.now() - 8 * 24 * 60 * 60 * 1000).toISOString(), // 8 days ago\n          distanceKm: 6.0,\n          durationMin: 35,\n          calories: 450,\n          avgHeartRate: 132,\n          maxHeartRate: 141,\n          avgCadence: 175,\n          maxCadence: 178,\n          avgSpeedKmh: 10.28,\n          maxSpeedKmh: 11.2,\n          avgPace: \'05:50\',\n          deviceBrand: \'Garmin\',\n          deviceModel: \'Forerunner 955\',\n          notes: \'Ritmo blando dopo le ripetute del giorno prima. Clima caldo umido ma gestibile. Battiti bassi come pianificato.\',\n          laps: [\n            { lapIndex: 1, distanceKm: 6.0, durationSec: 2100, calories: 450, avgHeartRate: 132, maxHeartRate: 141, avgCadence: 175 }\n          ]\n        },\n        {\n          id: \'act_5\',\n          sport: \'Running\',\n          name: \'Ripetute Medie 4x1000m\',\n          date: new Date(Date.now() - 10 * 24 * 60 * 60 * 1000).toISOString(), // 10 days ago\n          distanceKm: 9.0,\n          durationMin: 47,\n          calories: 710,\n          avgHeartRate: 156,\n          maxHeartRate: 178,\n          avgCadence: 181,\n          maxCadence: 188,\n          avgSpeedKmh: 11.49,\n          maxSpeedKmh: 15.5,\n          avgPace: \'05:13\',\n          deviceBrand: \'Garmin\',\n          deviceModel: \'Forerunner 955\',\n          notes: \'Target 1000m a 4:30/km. Tempi effettivi: 4:28, 4:27, 4:31, 4:25. Sensazioni di fatica controllata, recupero di 2 minuti di corsa lenta tra le serie.\',\n          laps: [\n            { lapIndex: 1, distanceKm: 2.0, durationSec: 660, calories: 150, avgHeartRate: 135, maxHeartRate: 145, avgCadence: 176 },\n            { lapIndex: 2, distanceKm: 4.0, durationSec: 1080, calories: 320, avgHeartRate: 165, maxHeartRate: 178, avgCadence: 183 },\n            { lapIndex: 3, distanceKm: 3.0, durationSec: 1080, calories: 240, avgHeartRate: 144, maxHeartRate: 152, avgCadence: 176 }\n          ]\n        }\n      ];\n      fs.writeFileSync(ACTIVITIES_FILE, JSON.stringify(defaultActivities, null, 2));\n    }\n\n    // Default Chat History\n    if (!fs.existsSync(CHAT_HISTORY_FILE)) {\n      const defaultChat: ChatMessage[] = [\n        {\n          id: \'chat_init\',\n          sender: \'assistant\',\n          text: `Ciao, Runner! \360\237\217\203\\n\\nBenvenuto sul tuo **Running Coach AI**. Sono qui per aiutarti a migliorare la tua forma fisica, strutturare le tue sessioni di allenamento ed analizzare le tue statistiche di corsa.\\n\\nEcco cosa posso fare per te:\\n1. **Analisi veloce (Groq)**: Chiedimi pareri sulle tue metriche di corsa, consigli di postura, scarpe o nutrizione.\\n2. **Programma Settimanale (Premium)**: Chiedimi di creare un piano di allenamento personalizzato scrivendo formule tipo \"*crea un piano per una maratona*\" o \"*preparami una settimana ad alta intensit\303\240*\". L\'AI Premium elaborer\303\240 per te un piano strutturato dettagliato.\\n3. **Analisi TCX**: Carica i file delle tue sessioni Garmin o Strava (.tcx) nella sezione **History** per popolare automaticamente il tuo grafico e le tue statistiche personali!\\n\\nCome posso aiutarti oggi?`,\n          timestamp: new Date().toISOString()\n        }\n      ];\n      fs.writeFileSync(CHAT_HISTORY_FILE, JSON.stringify(defaultChat, null, 2));\n    }\n\n    // Default Saved Plans\n    if (!fs.existsSync(TRAINING_PLANS_FILE)) {\n      fs.writeFileSync(TRAINING_PLANS_FILE, JSON.stringify([], null, 2));\n    }\n\n  } catch (error) {\n    console.error(\'Error initializing database:\', error);\n  }\n}\n\n// Data read/write utilities\nexport async function getActivities(): Promise<Activity[]> {\n  await initializeDb();\n  try {\n    const data = await fs.promises.readFile(ACTIVITIES_FILE, \'utf8\');\n    return JSON.parse(data) as Activity[];\n  } catch {\n    return [];\n  }\n}\n\nexport async function saveActivities(activities: Activity[]): Promise<void> {\n  await initializeDb();\n  await fs.promises.writeFile(ACTIVITIES_FILE, JSON.stringify(activities, null, 2));\n}\n\nexport async function getChatHistory(): Promise<ChatMessage[]> {\n  await initializeDb();\n  try {\n    const data = await fs.promises.readFile(CHAT_HISTORY_FILE, \'utf8\');\n    return JSON.parse(data) as ChatMessage[];\n  } catch {\n    return [];\n  }\n}\n\nexport async function saveChatHistory(history: ChatMessage[]): Promise<void> {\n  await initializeDb();\n  await fs.promises.writeFile(CHAT_HISTORY_FILE, JSON.stringify(history, null, 2));\n}\n\nexport async function clearChatHistory(): Promise<void> {\n  await initializeDb();\n  const initMessage: ChatMessage[] = [\n    {\n      id: \'chat_init\',\n      sender: \'assistant\',\n      text: `Ciao, Runner! \360\237\217\203\\n\\nBenvenuto sul tuo **Running Coach AI**. Sono qui per aiutarti a migliorare la tua forma fisica, strutturare le tue sessioni di allenamento ed analizzare le tue statistiche di corsa.\\n\\nEcco cosa posso fare per te:\\n1. **Analisi veloce (Groq)**: Chiedimi pareri sulle tue metriche di corsa, consigli di postura, scarpe o nutrizione.\\n2. **Programma Settimanale (Premium)**: Chiedimi di creare un piano di allenamento personalizzato scrivendo formule tipo \"*crea un piano per una maratona*\" o \"*preparami una settimana ad alta intensit\303\240*\". L\'AI Premium elaborer\303\240 per te un piano strutturato dettagliato.\\n3. **Analisi TCX**: Carica i file delle tue sessioni Garmin o Strava (.tcx) nella sezione **History** per popolare automaticamente il tuo grafico e le tue statistiche personali!\\n\\nCome posso aiutarti oggi?`,\n      timestamp: new Date().toISOString()\n    }\n  ];\n  await saveChatHistory(initMessage);\n}\n\nexport async function getTrainingPlans(): Promise<any[]> {\n  await initializeDb();\n  try {\n    const data = await fs.promises.readFile(TRAINING_PLANS_FILE, \'utf8\');\n    return JSON.parse(data) as any[];\n  } catch {\n    return [];\n  }\n}\n\nexport async function saveTrainingPlan(plan: any): Promise<void> {\n  await initializeDb();\n  try {\n    const plans = await getTrainingPlans();\n    plans.push(plan);\n    await fs.promises.writeFile(TRAINING_PLANS_FILE, JSON.stringify(plans, null, 2));\n  } catch (error) {\n    console.error(\'Error saving training plan:\', error);\n  }\n}\n"
    }
