          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          x={x}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          y=\"188\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          fill=\"#94a3b8\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          fontSize=\"9\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
