          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Find max distance to scale the bars"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const maxDistance = Math.max(...chartData.map(d => d.distanceKm), 10);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Convert \"MM:SS\" pace to seconds for charting"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const paceToSeconds = (paceStr: string) => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (!paceStr || !paceStr.includes(\':\')) return 300; // default 5:00"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const [m, s] = paceStr.split(\':\').map(Number);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return m * 60 + s;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  };"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const pacesInSecs = chartData.map(d => paceToSeconds(d.avgPace));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const maxPaceSecs = Math.max(...pacesInSecs, 400);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const minPaceSecs = Math.min(...pacesInSecs, 240);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
