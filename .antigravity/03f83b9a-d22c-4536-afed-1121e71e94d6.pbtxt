ver:text-white cursor-pointer\\\"><svg class=\\\"w-5 h-5\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" viewBox=\\\"0 0 24 24\\\"><path stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\" stroke-width=\\\"2\\\" d=\\\"M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z\\\"/></svg></div>\\n      <div class=\\\"p-2 text-gray-500 hover:text-white cursor-pointer\\\"><svg class=\\\"w-5 h-5\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" viewBox=\\\"0 0 24 24\\\"><path stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\" stroke-width=\\\"2\\\" d=\\\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\\\"/></svg></div>\\n      <div class=\\\"mt-auto p-2 text-gray-500 hover:text-white cursor-pointer\\\"><svg class=\\\"w-5 h-5\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" viewBox=\\\"0 0 24 24\\\"><path stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\" stroke-width=\\\"2\\\" d=\\\"M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z\\\"/><path stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\" stroke-width=\\\"2\\\" d=\\\"M15 12a3 3 0 11-6 0 3 3 0 016 0z\\\"/></svg></div>\\n    </nav>\\n\\n    <!-- Main Content Grid -->\\n    <div class=\\\"flex-1 grid grid-cols-12 gap-px bg-white/5\\\">\\n      \\n      <!-- Chat Area (Center) -->\\n      <div class=\\\"col-span-5 bg-[#0B0C0E] flex flex-col overflow-hidden\\\">\\n        <div class=\\\"p-4 border-b border-white/5 bg-[#0F1115]/50 flex justify-between items-center\\\">\\n          <h2 class=\\\"text-xs font-bold uppercase tracking-widest text-gray-400\\\">Coach Terminal</h2>\\n          <button class=\\\"text-[10px] text-[#CCFF00] hover:underline\\\">Clear History</button>\\n        </div>\\n        <div class=\\\"flex-1 p-6 space-y-6 overflow-hidden\\\">\\n          <div class=\\\"flex flex-col gap-1\\\">\\n            <div class=\\\"text-[10px] font-mono text-gray-500 uppercase\\\">Coach - Groq-Llama3</div>\\n            <div class=\\\"bg-white/5 p-3 rounded-tr-xl rounded-br-xl rounded-bl-xl border-l-2 border-[#CCFF00] text-sm leading-relaxed\\\">\\n              Analizzando i tuoi file TCX dell\'ultima settimana. Hai mantenuto una cadenza media di 172 bpm. Ottimo lavoro.\\n            </div>\\n          </div>\\n          <div class=\\\"flex flex-col gap-1 items-end\\\">\\n            <div class=\\\"text-[10px] font-mono text-gray-500 uppercase\\\">User</div>\\n            <div class=\\\"bg-blue-600/20 text-blue-100 p-3 rounded-tl-xl rounded-br-xl rounded-bl-xl border-r-2 border-blue-500 text-sm\\\">\\n              Preparami un piano di allenamento per una maratona sub-4h.\\n            </div>\\n          </div>\\n          <div class=\\\"flex flex-col gap-1\\\">\\n            <div class=\\\"text-[10px] font-mono text-[#CCFF00] uppercase\\\">Coach - Premium Model (GPT-4o)</div>\\n            <div class=\\\"bg-[#CCFF00]/10 p-3 rounded-tr-xl rounded-br-xl rounded-bl-xl border-l-2 border-[#CCFF00] text-sm leading-relaxed\\\">\\n              Innesco modello Premium per pianificazione avanzata. Per un target sub-4h (5:40 min/km), basandomi sul tuo VO2Max stimato, propongo un ciclo di 12 settimane.\\n              <div class=\\\"mt-3 grid grid-cols-2 gap-2 text-[11px] font-mono\\\">\\n                <div class=\\\"bg-black/40 p-2 border border-white/5\\\">Week 1: 35km base</div>\\n                <div class=\\\"bg-black/40 p-2 border border-white/5\\\">Target: Interval 4x800m</div>\\n              </div>\\n            </div>\\n          </div>\\n        </div>\\n        <div class=\\\"p-4 bg-[#0F1115] border-t border-white/5\\\">\\n          <div class=\\\"relative\\\">\\n            <input type=\\\"text\\\" placeholder=\\\"Chiedi al coach (es: piano settimanale)...\\\" class=\\\"w-full bg-black/50 border border-white/10 rounded px-4 py-3 text-sm focus:outline-none focus:border-[#CCFF00]/50 placeholder-gray-600\\\">\\n            <div class=\\\"absolute right-3 top-3 flex gap-2\\\">\\n              <kbd class=\\\"bg-white/5 text-gray-500 px-1.5 py-0.5 rounded text-[10px] border border-white/10\\\">\342\214\230K</kbd>\\n            </div>\\n          </div>\\n        </div>\\n      </div>\\n\\n      <!-- Dashboard Stats (Right) -->\\n      <div class=\\\"col-span-7 bg-[#0B0C0E] overflow-hidden flex flex-col\\\">\\n        <!-- Top Stats -->\\n        <div class=\\\"grid grid-cols-4 h-32 border-b border-white/5\\\">\\n          <div class=\\\"border-r border-white/5 p-4 flex flex-col justify-center\\\">\\n            <span class=\\\"text-[10px] uppercase text-gray-500 font-bold mb-1\\\">Total Distance</span>\\n            <div class=\\\"text-2xl font-bold text-white\\\">142.8 <span class=\\\"text-xs font-normal text-gray-500\\\">km</span></div>\\n          </div>\\n          <div class=\\\"border-r border-white/5 p-4 flex flex-col justify-center\\\">\\n            <span class=\\\"text-[10px] uppercase text-gray-500 font-bold mb-1\\\">Avg Pace</span>\\n            <div class=\\\"text-2xl font-bold text-white\\\">4:52 <span class=\\\"text-xs font-normal text-gray-500\\\">/km</span></div>\\n          </div>\\n          <div class=\\\"border-r border-white/5 p-4 flex flex-col justify-center\\\">\\n            <span class=\\\"text-[10px] uppercase text-gray-500 font-bold mb-1\\\">Avg Heart Rate</span>\\n            <div class=\\\"text-2xl font-bold text-white\\\">158 <span class=\\\"text-xs font-normal text-gray-500\\\">bpm</span></div>\\n          </div>\\n          <div class=\\\"p-4 flex flex-col justify-center\\\">\\n            <span class=\\\"text-[10px] uppercase text-gray-500 font-bold mb-1\\\">Total Time</span>\\n            <div class=\\\"text-2xl font-bold text-white\\\">12.5 <span class=\\\"text-xs font-normal text-gray-500\\\">hrs</span></div>\\n          </div>\\n        </div>\\n\\n        <!-- Middle Content -->\\n        <div class=\\\"flex-1 grid grid-cols-2 overflow-hidden\\\">\\n          <!-- Weekly Progress -->\\n          <div class=\\\"p-6 border-r border-white/5\\\">\\n            <div class=\\\"flex justify-between items-center mb-6\\\">\\n              <h3 class=\\\"text-xs font-bold uppercase tracking-widest text-gray-400\\\">Intensity Graph</h3>\\n              <span class=\\\"text-[10px] text-gray-500\\\">Last 7 Days</span>\\n            </div>\\n            <div class=\\\"flex items-end gap-1.5 h-32\\\">\\n              <div class=\\\"flex-1 bg-white/5 rounded-t-sm h-[40%]\\\"></div>\\n              <div class=\\\"flex-1 bg-white/5 rounded-t-sm h-[65%]\\\"></div>\\n              <div class=\\\"flex-1 bg-[#CCFF00]/40 rounded-t-sm h-[90%]\\\"></div>\\n              <div class=\\\"flex-1 bg-white/5 rounded-t-sm h-[30%]\\\"></div>\\n              <div class=\\\"flex-1 bg-white/5 rounded-t-sm h-[75%]\\\"></div>\\n              <div class=\\\"flex-1 bg-[#CCFF00] rounded-t-sm h-[100%]\\\"></div>\\n              <div class=\\\"flex-1 bg-white/5 rounded-t-sm h-[0%]\\\"></div>\\n            </div>\\n            <div class=\\\"flex justify-between mt-2 text-[9px] font-mono text-gray-600\\\">\\n              <span>MON</span><span>TUE</span><span>WED</span><span>THU</span><span>FRI</span><span>SAT</span><span>SUN</span>\\n            </div>\\n\\n            <div class=\\\"mt-8 space-y-4\\\">\\n              <div class=\\\"bg-white/5 p-3 rounded flex items-center gap-4\\\">\\n                <div class=\\\"w-10 h-10 rounded-full border-2 border-orange-500 flex items-center justify-center text-xs font-bold\\\">52</div>\\n                <div>\\n                  <div class=\\\"text-xs text-white font-bold uppercase\\\">Training Load</div>\\n                  <div class=\\\"text-[10px] text-gray-500\\\">Moderate - Recovery suggested</div>\\n                </div>\\n              </div>\\n              <div class=\\\"bg-white/5 p-3 rounded flex items-center gap-4\\\">\\n                <div class=\\\"w-10 h-10 rounded-full border-2 border-blue-500 flex items-center justify-center text-xs font-bold\\\">12h</div>\\n                <div>\\n                  <div class=\\\"text-xs text-white font-bold uppercase\\\">Est. Recovery</div>\\n                  <div class=\\\"text-[10px] text-gray-500\\\">Next hard session in 24 hours</div>\\n                </div>\\n              </div>\\n            </div>\\n          </div>\\n\\n          <!-- Recent Activities -->\\n          <div class=\\\"p-6\\\">\\n            <h3 class=\\\"text-xs font-bold uppercase tracking-widest text-gray-400 mb-4\\\">Recent Activities</h3>\\n            <div class=\\\"space-y-3\\\">\\n              <div class=\\\"p-3 bg-white/5 border border-white/5 rounded flex justify-between items-center group hover:border-[#CCFF00]/50 cursor-pointer\\\">\\n                <div>\\n                  <div class=\\\"text-xs font-bold text-white uppercase\\\">Morning Tempo</div>\\n                  <div class=\\\"text-[10px] text-gray-500\\\">Yesterday \342\200\242 12.4 km</div>\\n                </div>\\n                <div class=\\\"text-right\\\">\\n                  <div class=\\\"text-xs font-mono font-bold\\\">4:35/km</div>\\n                  <div class=\\\"text-[9px] text-gray-500 uppercase\\\">Gold Medal</div>\\n                </div>\\n              </div>\\n              <div class=\\\"p-3 bg-white/5 border border-white/5 rounded flex justify-between items-center\\\">\\n                <div>\\n                  <div class=\\\"text-xs font-bold text-white uppercase\\\">Easy Base</div>\\n                  <div class=\\\"text-[10px] text-gray-500\\\">2 days ago \342\200\242 8.0 km</div>\\n                </div>\\n                <div class=\\\"text-right\\\">\\n                  <div class=\\\"text-xs font-mono font-bold\\\">5:12/km</div>\\n                  <div class=\\\"text-[9px] text-gray-400 uppercase\\\">Z2 Endurance</div>\\n                </div>\\n              </div>\\n              <div class=\\\"p-3 bg-white/5 border border-white/5 rounded flex justify-between items-center\\\">\\n                <div>\\n                  <div class=\\\"text-xs font-bold text-white uppercase\\\">Interval Repeats</div>\\n                  <div class=\\\"text-[10px] text-gray-500\\\">4 days ago \342\200\242 10.2 km</div>\\n                </div>\\n                <div class=\\\"text-right\\\">\\n                  <div class=\\\"text-xs font-mono font-bold text-[#CCFF00]\\\">4:10/km</div>\\n                  <div class=\\\"text-[9px] text-gray-400 uppercase font-bold\\\">High Intensity</div>\\n                </div>\\n              </div>\\n              <div class=\\\"p-3 bg-white/5 border border-white/5 rounded flex justify-between items-center opacity-50\\\">\\n                <div>\\n                  <div class=\\\"text-xs font-bold text-white uppercase\\\">Recovery Walk</div>\\n                  <div class=\\\"text-[10px] text-gray-500\\\">5 days ago \342\200\242 5.1 km</div>\\n                </div>\\n                <div class=\\\"text-right\\\">\\n                  <div class=\\\"text-xs font-mono font-bold\\\">8:40/km</div>\\n                  <div class=\\\"text-[9px] text-gray-400 uppercase\\\">Active Recov</div>\\n                </div>\\n              </div>\\n            </div>\\n            <button class=\\\"w-full mt-6 py-2 border border-white/10 rounded text-[10px] font-bold uppercase tracking-wider hover:bg-white/5\\\">View All History</button>\\n          </div>\\n        </div>\\n      </div>\\n    </div>\\n  </main>\\n\\n  <!-- Footer Status Bar -->\\n  <footer class=\\\"h-8 border-t border-white/10 bg-[#0A0A0A] px-4 flex items-center justify-between text-[10px] font-mono text-gray-500\\\">\\n    <div class=\\\"flex gap-4\\\">\\n      <span>Parser: TCX-V2.1</span>\\n      <span>Memory: JSON-LOCAL</span>\\n      <span>Port: 8502</span>\\n    </div>\\n    <div class=\\\"flex gap-4 items-center\\\">\\n      <span class=\\\"text-[#CCFF00]\\\">\342\227\217 LLM Streaming</span>\\n      <span>Created with \342\235\244\357\270\217 for serious runners</span>\\n    </div>\\n  </footer>\\n</div>\\n                    </body>\\n                  </html>\n[AIS_METADATA_SECTION_END]"
    items {
      text: "Apply the \"High Density\" design theme to the app.\n[AIS_METADATA_SECTION_START]\nDesign name: High Density\nDesign instructions: Extract ONLY the styling (colors, fonts, spacing, borders, shadows, backgrounds, gradients) and layout patterns (flexbox/grid structure, component arrangement) from the Design HTML below. Do NOT replace or restructure the existing app\'s HTML elements \342\200\224 preserve all existing components, content, and functionality. Only modify CSS/styling and adjust layout containers as needed to match the theme\'s aesthetic.\nDesign HTML:                   <!doctype html>\\n                  <html style=\\\"height: 100%; margin: 0;\\\">\\n                    <head>\\n                      <meta charset=\\\"UTF-8\\\" />\\n                      <meta name=\\\"viewport\\\" content=\\\"width=device-width, initial-scale=1.0\\\" />\\n                      <script src=\\\"https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4\\\"></script>\\n                      <link href=\\\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200\\\" rel=\\\"stylesheet\\\" />\\n                      <style>\\n                        body { margin: 0; height: 100%; display: flex; flex-direction: column; overflow: hidden; }\\n                        /* Fallback classes in case Tailwind fails to load in sandbox */\\n                        .h-full { height: 100%; }\\n                        .w-full { width: 100%; }\\n                        .flex { display: flex; }\\n                        .flex-col { flex-direction: column; }\\n                        .flex-1 { flex: 1 1 0%; }\\n                      </style>\\n                    </head>\\n                    <body>\\n                      <div class=\\\"bg-[#0B0C0E] text-slate-300 font-sans h-[768px] w-[1024px] flex flex-col overflow-hidden\\\">\\n  <!-- Header -->\\n  <header class=\\\"h-14 border-b border-white/10 flex items-center justify-between px-6 shrink-0 bg-[#0F1115]\\\">\\n    <div class=\\\"flex items-center gap-3\\\">\\n      <div class=\\\"w-8 h-8 bg-[#CCFF00] rounded-sm flex items-center justify-center\\\">\\n        <svg class=\\\"w-5 h-5 text-black\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" viewBox=\\\"0 0 24 24\\\"><path stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\" stroke-width=\\\"2.5\\\" d=\\\"M13 10V3L4 14h7v7l9-11h-7z\\\"/></svg>\\n      </div>\\n      <span class=\\\"font-bold text-white tracking-tight uppercase text-sm\\\">Running Coach AI <span class=\\\"text-[#CCFF00] italic\\\">Pro</span></span>\\n    </div>\\n    <div class=\\\"flex items-center gap-6\\\">\\n      <div class=\\\"flex gap-2\\\">\\n        <span class=\\\"text-[10px] uppercase font-bold text-gray-500 border border-white/10 px-2 py-0.5 rounded\\\">Groq Fast</span>\\n        <span class=\\\"text-[10px] uppercase font-bold text-[#CCFF00] border border-[#CCFF00]/20 bg-[#CCFF00]/5 px-2 py-0.5 rounded\\\">Premium Active</span>\\n      </div>\\n      <div class=\\\"h-4 w-[1px] bg-white/10\\\"></div>\\n      <div class=\\\"flex items-center gap-2\\\">\\n        <div class=\\\"w-2 h-2 bg-green-500 rounded-full shadow-[0_0_8px_rgba(34,197,94,0.6)]\\\"></div>\\n        <span class=\\\"text-xs font-mono text-gray-400\\\">System: Ready</span>\\n      </div>\\n    </div>\\n  </header>\\n\\n  <main class=\\\"flex flex-1 overflow-hidden\\\">\\n    <!-- Sidebar Nav -->\\n    <nav class=\\\"w-16 border-r border-white/5 bg-[#0F1115] flex flex-col items-center py-6 gap-8\\\">\\n      <div class=\\\"p-2 rounded bg-white/10 text-white cursor-pointer\\\"><svg class=\\\"w-5 h-5\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" viewBox=\\\"0 0 24 24\\\"><path stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\" stroke-width=\\\"2\\\" d=\\\"M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z\\\"/></svg></div>\\n      <div class=\\\"p-2 text-gray-500 hover:text-white cursor-pointer\\\"><svg class=\\\"w-5 h-5\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" viewBox=\\\"0 0 24 24\\\"><path stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\" stroke-width=\\\"2\\\" d=\\\"M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z\\\"/></svg></div>\\n      <div class=\\\"p-2 text-gray-500 hover:text-white cursor-pointer\\\"><svg class=\\\"w-5 h-5\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" viewBox=\\\"0 0 24 24\\\"><path stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\" stroke-width=\\\"2\\\" d=\\\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\\\"/></svg></div>\\n      <div class=\\\"mt-auto p-2 text-gray-500 hover:text-white cursor-pointer\\\"><svg class=\\\"w-5 h-5\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" viewBox=\\\"0 0 24 24\\\"><path stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\" stroke-width=\\\"2\\\" d=\\\"M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z\\\"/><path stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\" stroke-width=\\\"2\\\" d=\\\"M15 12a3 3 0 11-6 0 3 3 0 016 0z\\\"/></svg></div>\\n    </nav>\\n\\n    <!-- Main Content Grid -->\\n    <div class=\\\"flex-1 grid grid-cols-12 gap-px bg-white/5\\\">\\n      \\n      <!-- Chat Area (Center) -->\\n      <div class=\\\"col-span-5 bg-[#0B0C0E] flex flex-col overflow-hidden\\\">\\n        <div class=\\\"p-4 border-b border-white/5 bg-[#0F1115]/50 flex justify-between items-center\\\">\\n          <h2 class=\\\"text-xs font-bold uppercase tracking-widest text-gray-400\\\">Coach Terminal</h2>\\n          <button class=\\\"text-[10px] text-[#CCFF00] hover:underline\\\">Clear History</button>\\n        </div>\\n        <div class=\\\"flex-1 p-6 space-y-6 overflow-hidden\\\">\\n          <div class=\\\"flex flex-col gap-1\\\">\\n            <div class=\\\"text-[10px] font-mono text-gray-500 uppercase\\\">Coach - Groq-Llama3</div>\\n            <div class=\\\"bg-white/5 p-3 rounded-tr-xl rounded-br-xl rounded-bl-xl border-l-2 border-[#CCFF00] text-sm leading-relaxed\\\">\\n              Analizzando i tuoi file TCX dell\'ultima settimana. Hai mantenuto una cadenza media di 172 bpm. Ottimo lavoro.\\n            </div>\\n          </div>\\n          <div class=\\\"flex flex-col gap-1 items-end\\\">\\n            <div class=\\\"text-[10px] font-mono text-gray-500 uppercase\\\">User</div>\\n            <div class=\\\"bg-blue-600/20 text-blue-100 p-3 rounded-tl-xl rounded-br-xl rounded-bl-xl border-r-2 border-blue-500 text-sm\\\">\\n              Preparami un piano di allenamento per una maratona sub-4h.\\n            </div>\\n          </div>\\n          <div class=\\\"flex flex-col gap-1\\\">\\n            <div class=\\\"text-[10px] font-mono text-[#CCFF00] uppercase\\\">Coach - Premium Model (GPT-4o)</div>\\n            <div class=\\\"bg-[#CCFF00]/10 p-3 rounded-tr-xl rounded-br-xl rounded-bl-xl border-l-2 border-[#CCFF00] text-sm leading-relaxed\\\">\\n              Innesco modello Premium per pianificazione avanzata. Per un target sub-4h (5:40 min/km), basandomi sul tuo VO2Max stimato, propongo un ciclo di 12 settimane.\\n              <div class=\\\"mt-3 grid grid-cols-2 gap-2 text-[11px] font-mono\\\">\\n                <div class=\\\"bg-black/40 p-2 border border-white/5\\\">Week 1: 35km base</div>\\n                <div class=\\\"bg-black/40 p-2 border border-white/5\\\">Target: Interval 4x800m</div>\\n              </div>\\n            </div>\\n          </div>\\n        </div>\\n        <div class=\\\"p-4 bg-[#0F1115] border-t border-white/5\\\">\\n          <div class=\\\"relative\\\">\\n            <input type=\\\"text\\\" placeholder=\\\"Chiedi al coach (es: piano settimanale)...\\\" class=\\\"w-full bg-black/50 border border-white/10 rounded px-4 py-3 text-sm focus:outline-none focus:border-[#CCFF00]/50 placeholder-gray-600\\\">\\n            <div class=\\\"absolute right-3 top-3 flex gap-2\\\">\\n              <kbd class=\\\"bg-white/5 text-gray-500 px-1.5 py-0.5 rounded text-[10px] border border-white/10\\\">\342\214\230K</kbd>\\n            </div>\\n          </div>\\n        </div>\\n      </div>\\n\\n      <!-- Dashboard Stats (Right) -->\\n      <div class=\\\"col-span-7 bg-[#0B0C0E] overflow-hidden flex flex-col\\\">\\n        <!-- Top Stats -->\\n        <div class=\\\"grid grid-cols-4 h-32 border-b border-white/5\\\">\\n          <div class=\\\"border-r border-white/5 p-4 flex flex-col justify-center\\\">\\n            <span class=\\\"text-[10px] uppercase text-gray-500 font-bold mb-1\\\">Total Distance</span>\\n            <div class=\\\"text-2xl font-bold text-white\\\">142.8 <span class=\\\"text-xs font-normal text-gray-500\\\">km</span></div>\\n          </div>\\n          <div class=\\\"border-r border-white/5 p-4 flex flex-col justify-center\\\">\\n            <span class=\\\"text-[10px] uppercase text-gray-500 font-bold mb-1\\\">Avg Pace</span>\\n            <div class=\\\"text-2xl font-bold text-white\\\">4:52 <span class=\\\"text-xs font-normal text-gray-500\\\">/km</span></div>\\n          </div>\\n          <div class=\\\"border-r border-white/5 p-4 flex flex-col justify-center\\\">\\n            <span class=\\\"text-[10px] uppercase text-gray-500 font-bold mb-1\\\">Avg Heart Rate</span>\\n            <div class=\\\"text-2xl font-bold text-white\\\">158 <span class=\\\"text-xs font-normal text-gray-500\\\">bpm</span></div>\\n          </div>\\n          <div class=\\\"p-4 flex flex-col justify-center\\\">\\n            <span class=\\\"text-[10px] uppercase text-gray-500 font-bold mb-1\\\">Total Time</span>\\n            <div class=\\\"text-2xl font-bold text-white\\\">12.5 <span class=\\\"text-xs font-normal text-gray-500\\\">hrs</span></div>\\n          </div>\\n        </div>\\n\\n        <!-- Middle Content -->\\n        <div class=\\\"flex-1 grid grid-cols-2 overflow-hidden\\\">\\n          <!-- Weekly Progress -->\\n          <div class=\\\"p-6 border-r border-white/5\\\">\\n            <div class=\\\"flex justify-between items-center mb-6\\\">\\n              <h3 class=\\\"text-xs font-bold uppercase tracking-widest text-gray-400\\\">Intensity Graph</h3>\\n              <span class=\\\"text-[10px] text-gray-500\\\">Last 7 Days</span>\\n            </div>\\n            <div class=\\\"flex items-end gap-1.5 h-32\\\">\\n              <div class=\\\"flex-1 bg-white/5 rounded-t-sm h-[40%]\\\"></div>\\n              <div class=\\\"flex-1 bg-white/5 rounded-t-sm h-[65%]\\\"></div>\\n              <div class=\\\"flex-1 bg-[#CCFF00]/40 rounded-t-sm h-[90%]\\\"></div>\\n              <div class=\\\"flex-1 bg-white/5 rounded-t-sm h-[30%]\\\"></div>\\n              <div class=\\\"flex-1 bg-white/5 rounded-t-sm h-[75%]\\\"></div>\\n              <div class=\\\"flex-1 bg-[#CCFF00] rounded-t-sm h-[100%]\\\"></div>\\n              <div class=\\\"flex-1 bg-white/5 rounded-t-sm h-[0%]\\\"></div>\\n            </div>\\n            <div class=\\\"flex justify-between mt-2 text-[9px] font-mono text-gray-600\\\">\\n              <span>MON</span><span>TUE</span><span>WED</span><span>THU</span><span>FRI</span><span>SAT</span><span>SUN</span>\\n            </div>\\n\\n            <div class=\\\"mt-8 space-y-4\\\">\\n              <div class=\\\"bg-white/5 p-3 rounded flex items-center gap-4\\\">\\n                <div class=\\\"w-10 h-10 rounded-full border-2 border-orange-500 flex items-center justify-center text-xs font-bold\\\">52</div>\\n                <div>\\n                  <div class=\\\"text-xs text-white font-bold uppercase\\\">Training Load</div>\\n                  <div class=\\\"text-[10px] text-gray-500\\\">Moderate - Recovery suggested</div>\\n                </div>\\n              </div>\\n              <div class=\\\"bg-white/5 p-3 rounded flex items-center gap-4\\\">\\n                <div class=\\\"w-10 h-10 rounded-full border-2 border-blue-500 flex items-center justify-center text-xs font-bold\\\">12h</div>\\n                <div>\\n                  <div class=\\\"text-xs text-white font-bold uppercase\\\">Est. Recovery</div>\\n                  <div class=\\\"text-[10px] text-gray-500\\\">Next hard session in 24 hours</div>\\n                </div>\\n              </div>\\n            </div>\\n          </div>\\n\\n          <!-- Recent Activities -->\\n          <div class=\\\"p-6\\\">\\n            <h3 class=\\\"text-xs font-bold uppercase tracking-widest text-gray-400 mb-4\\\">Recent Activities</h3>\\n            <div class=\\\"space-y-3\\\">\\n              <div class=\\\"p-3 bg-white/5 border border-white/5 rounded flex justify-between items-center group hover:border-[#CCFF00]/50 cursor-pointer\\\">\\n                <div>\\n                  <div class=\\\"text-xs font-bold text-white uppercase\\\">Morning Tempo</div>\\n                  <div class=\\\"text-[10px] text-gray-500\\\">Yesterday \342\200\242 12.4 km</div>\\n                </div>\\n                <div class=\\\"text-right\\\">\\n                  <div class=\\\"text-xs font-mono font-bold\\\">4:35/km</div>\\n                  <div class=\\\"text-[9px] text-gray-500 uppercase\\\">Gold Medal</div>\\n                </div>\\n              </div>\\n              <div class=\\\"p-3 bg-white/5 border border-white/5 rounded flex justify-between items-center\\\">\\n                <div>\\n                  <div class=\\\"text-xs font-bold text-white uppercase\\\">Easy Base</div>\\n                  <div class=\\\"text-[10px] text-gray-500\\\">2 days ago \342\200\242 8.0 km</div>\\n                </div>\\n                <div class=\\\"text-right\\\">\\n                  <div class=\\\"text-xs font-mono font-bold\\\">5:12/km</div>\\n                  <div class=\\\"text-[9px] text-gray-400 uppercase\\\">Z2 Endurance</div>\\n                </div>\\n              </div>\\n              <div class=\\\"p-3 bg-white/5 border border-white/5 rounded flex justify-between items-center\\\">\\n                <div>\\n                  <div class=\\\"text-xs font-bold text-white uppercase\\\">Interval Repeats</div>\\n                  <div class=\\\"text-[10px] text-gray-500\\\">4 days ago \342\200\242 10.2 km</div>\\n                </div>\\n                <div class=\\\"text-right\\\">\\n                  <div class=\\\"text-xs font-mono font-bold text-[#CCFF00]\\\">4:10/km</div>\\n                  <div class=\\\"text-[9px] text-gray-400 uppercase font-bold\\\">High Intensity</div>\\n                </div>\\n              </div>\\n              <div class=\\\"p-3 bg-white/5 border border-white/5 rounded flex justify-between items-center opacity-50\\\">\\n                <div>\\n                  <div class=\\\"text-xs font-bold text-white uppercase\\\">Recovery Walk</div>\\n                  <div class=\\\"text-[10px] text-gray-500\\\">5 days ago \342\200\242 5.1 km</div>\\n                </div>\\n                <div class=\\\"text-right\\\">\\n                  <div class=\\\"text-xs font-mono font-bold\\\">8:40/km</div>\\n                  <div class=\\\"text-[9px] text-gray-400 uppercase\\\">Active Recov</div>\\n                </div>\\n              </div>\\n            </div>\\n            <button class=\\\"w-full mt-6 py-2 border border-white/10 rounded text-[10px] font-bold uppercase tracking-wider hover:bg-white/5\\\">View All History</button>\\n          </div>\\n        </div>\\n      </div>\\n    </div>\\n  </main>\\n\\n  <!-- Footer Status Bar -->\\n  <footer class=\\\"h-8 border-t border-white/10 bg-[#0A0A0A] px-4 flex items-center justify-between text-[10px] font-mono text-gray-500\\\">\\n    <div class=\\\"flex gap-4\\\">\\n      <span>Parser: TCX-V2.1</span>\\n      <span>Memory: JSON-LOCAL</span>\\n      <span>Port: 8502</span>\\n    </div>\\n    <div class=\\\"flex gap-4 items-center\\\">\\n      <span class=\\\"text-[#CCFF00]\\\">\342\227\217 LLM Streaming</span>\\n      <span>Created with \342\235\244\357\270\217 for serious runners</span>\\n    </div>\\n  </footer>\\n</div>\\n                    </body>\\n                  </html>\n[AIS_METADATA_SECTION_END]"
    }
  }
}
