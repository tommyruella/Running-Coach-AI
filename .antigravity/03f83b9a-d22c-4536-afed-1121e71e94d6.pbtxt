        }
        lines {
          text: "      {/* Advice Card */}"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "      <div className=\"bg-gradient-to-r from-emerald-950/20 to-slate-950/40 border border-emerald-900/40 rounded-2xl p-5 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 shadow-lg shadow-emerald-950/5\">"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "      {/* Advice Card - Styled to match High Density System terminal */}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      <div className=\"bg-[#0F1115] border border-white/10 p-5 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 rounded\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        <div className=\"flex gap-4 items-start\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "          <div className=\"p-3 bg-emerald-500/10 text-emerald-400 rounded-xl\">"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "            <Cpu className=\"h-6 w-6\" />"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "          </div>"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "          <div>"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "            <h4 className=\"text-sm font-semibold text-white\">Consiglio Coach del Giorno</h4>"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "            <p className=\"text-xs text-slate-300 mt-1 max-w-2xl leading-relaxed\">"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "              In base ai tuoi ultimi allenamenti, la tua frequenza cardiaca media \303\250 stabile a {stats.avgHr} bpm. Per la prossima corsa, focalizzati sul mantenere un ritmo di recupero in Zona 2 per stimolare la capillarizzazione periferica senza affaticare il sistema nervoso centrale."
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "          <div className=\"p-2.5 bg-lime-accent/10 text-lime-accent rounded-sm border border-lime-accent/20 shrink-0\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            <Cpu className=\"h-5 w-5\" />"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          </div>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          <div>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            <h4 className=\"text-xs font-bold uppercase tracking-widest text-white\">Daily Advisory System</h4>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            <p className=\"text-xs text-slate-300 mt-1 max-w-3xl leading-relaxed font-sans\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              Analisi biometrica: frequenza cardiaca media stabile a <span className=\"text-lime-accent font-bold font-mono\">{stats.avgHr} bpm</span>. In base ai volumi TCX elaborati, si consiglia un ciclo di corsa a bassa intensit\303\240 (Zona 2) per ottimizzare la gittata sistolica periferica senza incrementare l\'indice di stress neurale."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            </p>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "          </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  );"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  );"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
      }
    }
    instruction: "Apply High Density styling (colors, panels, fonts, lime green highlights) to the Dashboard component"
    replacement_infos {
      original_chunk {
        target_content: "  return (\n    <div className=\"space-y-8\" id=\"dashboard-tab\">\n      \n      {/* Dynamic Welcome Heading */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4\">\n        <div>\n          <h2 className=\"text-2xl font-bold tracking-tight text-white flex items-center gap-2\">\n            <TrendingUp className=\"h-6 w-6 text-emerald-400\" />\n            La Tua Condizione\n          </h2>\n          <p className=\"text-slate-400 text-sm mt-1\">\n            Analisi delle prestazioni, volumi settimanali e progressi.\n          </p>\n        </div>\n        <div className=\"text-xs bg-slate-800 border border-slate-700/60 rounded-full px-3 py-1.5 text-slate-300 flex items-center gap-1.5 self-start md:self-auto\">\n          <span className=\"h-2 w-2 rounded-full bg-emerald-500 animate-pulse\"></span>\n          Pronto per correre \342\200\242 Stato: Ottimizzato\n        </div>\n      </div>\n\n      {/* Stats Bento Grid */}\n      <div className=\"grid grid-cols-2 lg:grid-cols-5 gap-4\">\n        \n        {/* Stat 1: Total Km */}\n        <motion.div \n          whileHover={{ y: -4 }}\n          className=\"bg-slate-900 border border-slate-800 p-4 rounded-2xl flex flex-col justify-between h-32 relative overflow-hidden group shadow-lg shadow-black/10\"\n          id=\"stat-km\"\n        >\n          <div className=\"flex items-center justify-between\">\n            <span className=\"text-xs font-medium text-slate-400\">Distanza Totale</span>\n            <div className=\"p-2 bg-emerald-500/10 rounded-xl text-emerald-400 group-hover:bg-emerald-500/20 transition-colors\">\n              <Zap className=\"h-4 w-4\" />\n            </div>\n          </div>\n          <div className=\"mt-2\">\n            <span className=\"text-3xl font-extrabold text-white tracking-tight\">{stats.totalKm}</span>\n            <span className=\"text-xs text-slate-400 ml-1 font-mono\">km</span>\n          </div>\n          <div className=\"text-[10px] text-slate-500 flex items-center gap-1\">\n            <span>Volume totale registrato</span>\n          </div>\n          <div className=\"absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-emerald-500 to-emerald-400 opacity-60\" />\n        </motion.div>\n\n        {/* Stat 2: Total Hours */}\n        <motion.div \n          whileHover={{ y: -4 }}\n          className=\"bg-slate-900 border border-slate-800 p-4 rounded-2xl flex flex-col justify-between h-32 relative overflow-hidden group shadow-lg shadow-black/10\"\n          id=\"stat-hours\"\n        >\n          <div className=\"flex items-center justify-between\">\n            <span className=\"text-xs font-medium text-slate-400\">Tempo Totale</span>\n            <div className=\"p-2 bg-cyan-500/10 rounded-xl text-cyan-400 group-hover:bg-cyan-500/20 transition-colors\">\n              <Clock className=\"h-4 w-4\" />\n            </div>\n          </div>\n          <div className=\"mt-2\">\n            <span className=\"text-3xl font-extrabold text-white tracking-tight\">{stats.totalDurationHours}</span>\n            <span className=\"text-xs text-slate-400 ml-1 font-mono\">ore</span>\n          </div>\n          <div className=\"text-[10px] text-slate-500\">\n            Attivit\303\240 cardio cumulative\n          </div>\n          <div className=\"absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-cyan-500 to-cyan-400 opacity-60\" />\n        </motion.div>\n\n        {/* Stat 3: Avg Pace */}\n        <motion.div \n          whileHover={{ y: -4 }}\n          className=\"bg-slate-900 border border-slate-800 p-4 rounded-2xl flex flex-col justify-between h-32 relative overflow-hidden group shadow-lg shadow-black/10\"\n          id=\"stat-pace\"\n        >\n          <div className=\"flex items-center justify-between\">\n            <span className=\"text-xs font-medium text-slate-400\">Ritmo Medio</span>\n            <div className=\"p-2 bg-amber-500/10 rounded-xl text-amber-400 group-hover:bg-amber-500/20 transition-colors\">\n              <Activity className=\"h-4 w-4\" />\n            </div>\n          </div>\n          <div className=\"mt-2\">\n            <span className=\"text-3xl font-extrabold text-white tracking-tight font-mono\">{stats.avgPace}</span>\n            <span className=\"text-xs text-slate-400 ml-1\">/km</span>\n          </div>\n          <div className=\"text-[10px] text-slate-500\">\n            Andatura media registrata\n          </div>\n          <div className=\"absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-amber-500 to-amber-400 opacity-60\" />\n        </motion.div>\n\n        {/* Stat 4: Avg HR */}\n        <motion.div \n          whileHover={{ y: -4 }}\n          className=\"bg-slate-900 border border-slate-800 p-4 rounded-2xl flex flex-col justify-between h-32 relative overflow-hidden group shadow-lg shadow-black/10\"\n          id=\"stat-hr\"\n        >\n          <div className=\"flex items-center justify-between\">\n            <span className=\"text-xs font-medium text-slate-400\">FC Media</span>\n            <div className=\"p-2 bg-rose-500/10 rounded-xl text-rose-400 group-hover:bg-rose-500/20 transition-colors\">\n              <Heart className=\"h-4 w-4\" />\n            </div>\n          </div>\n          <div className=\"mt-2\">\n            <span className=\"text-3xl font-extrabold text-white tracking-tight\">{stats.avgHr}</span>\n            <span className=\"text-xs text-slate-400 ml-1 font-mono\">bpm</span>\n          </div>\n          <div className=\"text-[10px] text-slate-500\">\n            Battito medio in sessione\n          </div>\n          <div className=\"absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-rose-500 to-rose-400 opacity-60\" />\n        </motion.div>\n\n        {/* Stat 5: Total Activities */}\n        <motion.div \n          whileHover={{ y: -4 }}\n          className=\"bg-slate-900 border border-slate-800 p-4 rounded-2xl flex flex-col justify-between h-32 col-span-2 lg:col-span-1 relative overflow-hidden group shadow-lg shadow-black/10\"\n          id=\"stat-activities\"\n        >\n          <div className=\"flex items-center justify-between\">\n            <span className=\"text-xs font-medium text-slate-400\">Allenamenti</span>\n            <div className=\"p-2 bg-indigo-500/10 rounded-xl text-indigo-400 group-hover:bg-indigo-500/20 transition-colors\">\n              <Calendar className=\"h-4 w-4\" />\n            </div>\n          </div>\n          <div className=\"mt-2\">\n            <span className=\"text-3xl font-extrabold text-white tracking-tight\">{stats.totalActivities}</span>\n            <span className=\"text-xs text-slate-400 ml-1 font-mono\">tot</span>\n          </div>\n          <div className=\"text-[10px] text-slate-500\">\n            Attivit\303\240 TCX caricate\n          </div>\n          <div className=\"absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-indigo-500 to-indigo-400 opacity-60\" />\n        </motion.div>\n\n      </div>\n\n      {/* Main Dashboard Layout: Chart & Recent Activities */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        \n        {/* Progress Chart (2/3 width on desktop) */}\n        <div className=\"lg:col-span-2 bg-slate-900/50 border border-slate-800/80 rounded-2xl p-5 shadow-xl flex flex-col justify-between\">\n          <div>\n            <div className=\"flex items-center justify-between mb-4\">\n              <div>\n                <h3 className=\"text-md font-semibold text-white\">Trend Ultimi 5 Allenamenti</h3>\n                <p className=\"text-xs text-slate-400 mt-0.5\">Distanza (barre verdi) vs Ritmo (linea azzurra)</p>\n              </div>\n              <div className=\"flex items-center gap-3 text-[10px]\">\n                <div className=\"flex items-center gap-1.5 text-emerald-400\">\n                  <span className=\"h-2 w-2 rounded-full bg-emerald-500\"></span>\n                  km Corsa\n                </div>\n                <div className=\"flex items-center gap-1.5 text-cyan-400\">\n                  <span className=\"h-2 w-1.5 rounded-full bg-cyan-400\"></span>\n                  Ritmo (min/km)\n                </div>\n              </div>\n            </div>\n\n            {/* Custom SVG Responsive Chart */}\n            <div className=\"h-64 w-full relative pt-4\" id=\"svg-trend-chart\">\n              {chartData.length === 0 ? (\n                <div className=\"absolute inset-0 flex items-center justify-center text-slate-500 text-sm\">\n                  Nessun dato registrato. Carica un file TCX per visualizzare il grafico.\n                </div>\n              ) : (\n                <svg className=\"w-full h-full overflow-visible\" viewBox=\"0 0 500 200\" preserveAspectRatio=\"none\">\n                  {/* Grid Lines */}\n                  <line x1=\"0\" y1=\"30\" x2=\"500\" y2=\"30\" stroke=\"#1e293b\" strokeDasharray=\"3,3\" />\n                  <line x1=\"0\" y1=\"80\" x2=\"500\" y2=\"80\" stroke=\"#1e293b\" strokeDasharray=\"3,3\" />\n                  <line x1=\"0\" y1=\"130\" x2=\"500\" y2=\"130\" stroke=\"#1e293b\" strokeDasharray=\"3,3\" />\n                  <line x1=\"0\" y1=\"170\" x2=\"500\" y2=\"170\" stroke=\"#334155\" />\n\n                  {/* Render Distance Bars & Pace Line */}\n                  {chartData.map((d, index) => {\n                    const step = 500 / 6;\n                    const x = step * (index + 0.8);\n                    \n                    // Bar calculations (distance)\n                    const barHeight = (d.distanceKm / maxDistance) * 140;\n                    const yBar = 170 - barHeight;\n\n                    // Line calculations (pace)\n                    const paceSecs = paceToSeconds(d.avgPace);\n                    const normalizedPace = (paceSecs - minPaceSecs) / (maxPaceSecs - minPaceSecs || 1);\n                    // inverse because lower pace (smaller seconds) is better/higher on the chart\n                    const yLine = 40 + (normalizedPace * 100);\n\n                    return (\n                      <g key={d.id} className=\"cursor-pointer\">\n                        {/* Interactive Bar */}\n                        <motion.rect\n                          x={x - 12}\n                          y={yBar}\n                          width=\"24\"\n                          height={barHeight}\n                          rx=\"4\"\n                          fill=\"url(#emerald-grad)\"\n                          initial={{ scaleY: 0, originY: 1 }}\n                          animate={{ scaleY: 1 }}\n                          transition={{ delay: index * 0.1, duration: 0.5 }}\n                          onHoverStart={() => setHoveredIndex(index)}\n                          onHoverEnd={() => setHoveredIndex(null)}\n                          className=\"hover:opacity-90 transition-opacity\"\n                        />\n\n                        {/* Pace Dot */}\n                        <circle\n                          cx={x}\n                          cy={yLine}\n                          r=\"5\"\n                          fill=\"#22d3ee\"\n                          stroke=\"#0f172a\"\n                          strokeWidth=\"1.5\"\n                        />\n\n                        {/* Label Date */}\n                        <text\n                          x={x}\n                          y=\"188\"\n                          fill=\"#94a3b8\"\n                          fontSize=\"9\"\n                          textAnchor=\"middle\"\n                          fontFamily=\"monospace\"\n                        >\n                          {new Date(d.date).toLocaleDateString(\'it-IT\', { day: \'2-digit\', month: \'short\' })}\n                        </text>\n\n                        {/* Label value of Distance */}\n                        <text\n                          x={x}\n                          y={yBar - 6}\n                          fill=\"#34d399\"\n                          fontSize=\"9\"\n                          fontWeight=\"bold\"\n                          textAnchor=\"middle\"\n                        >\n                          {d.distanceKm}k\n                        </text>\n\n                        {/* Tooltip Overlay */}\n                        {hoveredIndex === index && (\n                          <g>\n                            <rect\n                              x={x < 250 ? x + 20 : x - 130}\n                              y=\"20\"\n                              width=\"120\"\n                              height=\"85\"\n                              rx=\"8\"\n                              fill=\"#1e293b\"\n                              stroke=\"#334155\"\n                              strokeWidth=\"1\"\n                            />\n                            <text x={x < 250 ? x + 30 : x - 120} y=\"38\" fill=\"#ffffff\" fontSize=\"9\" fontWeight=\"bold\">\n                              {d.name.substring(0, 15)}...\n                            </text>\n                            <text x={x < 250 ? x + 30 : x - 120} y=\"54\" fill=\"#94a3b8\" fontSize=\"8\">\n                              Distanza: <tspan fill=\"#34d399\" fontWeight=\"bold\">{d.distanceKm} km</tspan>\n                            </text>\n                            <text x={x < 250 ? x + 30 : x - 120} y=\"68\" fill=\"#94a3b8\" fontSize=\"8\">\n                              Ritmo: <tspan fill=\"#22d3ee\" fontWeight=\"bold\">{d.avgPace}/km</tspan>\n                            </text>\n                            <text x={x < 250 ? x + 30 : x - 120} y=\"82\" fill=\"#94a3b8\" fontSize=\"8\">\n                              Durata: {d.durationMin} min\n                            </text>\n                          </g>\n                        )}\n                      </g>\n                    );\n                  })}\n\n                  {/* Connected line between dots */}\n                  {chartData.length > 1 && (\n                    <path\n                      d={chartData.map((d, index) => {\n                        const step = 500 / 6;\n                        const x = step * (index + 0.8);\n                        const paceSecs = paceToSeconds(d.avgPace);\n                        const normalizedPace = (paceSecs - minPaceSecs) / (maxPaceSecs - minPaceSecs || 1);\n                        const yLine = 40 + (normalizedPace * 100);\n                        return `${index === 0 ? \'M\' : \'L\'} ${x} ${yLine}`;\n                      }).join(\' \')}\n                      fill=\"none\"\n                      stroke=\"#22d3ee\"\n                      strokeWidth=\"2\"\n                      strokeDasharray=\"4\"\n                      className=\"opacity-70 pointer-events-none\"\n                    />\n                  )}\n\n                  {/* Gradient definition */}\n                  <defs>\n                    <linearGradient id=\"emerald-grad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                      <stop offset=\"0%\" stopColor=\"#10b981\" />\n                      <stop offset=\"100%\" stopColor=\"#047857\" />\n                    </linearGradient>\n                  </defs>\n                </svg>\n              )}\n            </div>\n          </div>\n          \n          <div className=\"mt-4 pt-3 border-t border-slate-800 flex justify-between items-center text-xs text-slate-400\">\n            <span>Dati sincronizzati con il parser TCX di precisione.</span>\n            <button \n              onClick={onNavigateToHistory}\n              className=\"text-emerald-400 hover:text-emerald-300 font-medium flex items-center gap-0.5 transition-colors\"\n            >\n              Vedi storico\n              <ChevronRight className=\"h-3 w-3\" />\n            </button>\n          </div>\n        </div>\n\n        {/* Recent runs list */}\n        <div className=\"bg-slate-900/50 border border-slate-800/80 rounded-2xl p-5 shadow-xl flex flex-col justify-between\">\n          <div>\n            <h3 className=\"text-md font-semibold text-white mb-4\">Attivit\303\240 Recenti</h3>\n            <div className=\"space-y-3\">\n              {activities.slice(0, 4).map((act, index) => (\n                <div \n                  key={act.id} \n                  className=\"bg-slate-900 border border-slate-800/60 p-3 rounded-xl flex items-center justify-between group hover:border-emerald-500/30 transition-all duration-200\"\n                >\n                  <div className=\"flex items-center gap-3\">\n                    <div className=\"h-9 w-9 rounded-lg bg-emerald-500/10 text-emerald-400 flex items-center justify-center font-mono font-bold text-xs\">\n                      {act.distanceKm.toFixed(0)}\n                      <span className=\"text-[9px] font-normal\">k</span>\n                    </div>\n                    <div className=\"min-w-0\">\n                      <h4 className=\"text-xs font-semibold text-white truncate group-hover:text-emerald-400 transition-colors\">\n                        {act.name}\n                      </h4>\n                      <p className=\"text-[10px] text-slate-500 mt-0.5\">\n                        {new Date(act.date).toLocaleDateString(\'it-IT\', { day: \'numeric\', month: \'short\', hour: \'2-digit\', minute: \'2-digit\' })}\n                      </p>\n                    </div>\n                  </div>\n                  <div className=\"text-right\">\n                    <p className=\"text-xs font-mono font-bold text-white\">{act.avgPace}</p>\n                    <p className=\"text-[9px] text-slate-400 mt-0.5\">{act.durationMin} min</p>\n                  </div>\n                </div>\n              ))}\n\n              {activities.length === 0 && (\n                <div className=\"text-center py-8 text-slate-500 text-xs\">\n                  Ancora nessun allenamento inserito.\n                </div>\n              )}\n            </div>\n          </div>\n\n          <button \n            onClick={onNavigateToHistory}\n            className=\"w-full mt-4 bg-slate-800 border border-slate-700/60 hover:bg-slate-700/60 text-slate-200 text-xs font-semibold py-2 px-4 rounded-xl transition-colors flex items-center justify-center gap-1\"\n          >\n            Gestisci Allenamenti\n            <ChevronRight className=\"h-3.5 w-3.5\" />\n          </button>\n        </div>\n\n      </div>\n\n      {/* Advice Card */}\n      <div className=\"bg-gradient-to-r from-emerald-950/20 to-slate-950/40 border border-emerald-900/40 rounded-2xl p-5 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 shadow-lg shadow-emerald-950/5\">\n        <div className=\"flex gap-4 items-start\">\n          <div className=\"p-3 bg-emerald-500/10 text-emerald-400 rounded-xl\">\n            <Cpu className=\"h-6 w-6\" />\n          </div>\n          <div>\n            <h4 className=\"text-sm font-semibold text-white\">Consiglio Coach del Giorno</h4>\n            <p className=\"text-xs text-slate-300 mt-1 max-w-2xl leading-relaxed\">\n              In base ai tuoi ultimi allenamenti, la tua frequenza cardiaca media \303\250 stabile a {stats.avgHr} bpm. Per la prossima corsa, focalizzati sul mantenere un ritmo di recupero in Zona 2 per stimolare la capillarizzazione periferica senza affaticare il sistema nervoso centrale.\n            </p>\n          </div>\n        </div>\n      </div>\n\n    </div>"
        replacement_content: "  return (\n    <div className=\"space-y-6\" id=\"dashboard-tab\">\n      \n      {/* High Density Header Section */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-white/5 pb-4\">\n        <div>\n          <h2 className=\"text-lg font-bold uppercase tracking-wider text-white flex items-center gap-2\">\n            <TrendingUp className=\"h-5 w-5 text-lime-accent\" />\n            Performance & Conditioning\n          </h2>\n          <p className=\"text-gray-500 text-xs mt-0.5\">\n            Realtime metrics stream, volume analyses, and cardiovascular threshold tracking.\n          </p>\n        </div>\n        <div className=\"text-[10px] font-mono uppercase bg-lime-accent/5 border border-lime-accent/20 rounded px-2.5 py-1 text-lime-accent flex items-center gap-1.5 self-start md:self-auto\">\n          <span className=\"h-1.5 w-1.5 rounded-full bg-lime-accent animate-pulse\"></span>\n          Ready state \342\200\242 System optimized\n        </div>\n      </div>\n\n      {/* Stats Bento Grid - High Density styling */}\n      <div className=\"grid grid-cols-2 lg:grid-cols-5 gap-px bg-white/5 border border-white/10 overflow-hidden rounded\">\n        \n        {/* Stat 1: Total Km */}\n        <div \n          className=\"bg-highdensity-panel p-4 flex flex-col justify-between h-28 relative group\"\n          id=\"stat-km\"\n        >\n          <div className=\"flex items-center justify-between\">\n            <span className=\"text-[10px] uppercase font-bold tracking-wider text-gray-500\">Total Distance</span>\n            <div className=\"text-lime-accent\">\n              <Zap className=\"h-3.5 w-3.5\" />\n            </div>\n          </div>\n          <div>\n            <span className=\"text-2xl font-mono font-bold text-white tracking-tight\">{stats.totalKm}</span>\n            <span className=\"text-[10px] text-gray-500 ml-1 font-mono\">km</span>\n          </div>\n          <div className=\"text-[9px] font-mono text-gray-600 uppercase\">\n            Cumulative volume\n          </div>\n          <div className=\"absolute bottom-0 left-0 right-0 h-[2px] bg-lime-accent/40 group-hover:bg-lime-accent transition-colors\" />\n        </div>\n\n        {/* Stat 2: Total Hours */}\n        <div \n          className=\"bg-highdensity-panel p-4 flex flex-col justify-between h-28 relative group\"\n          id=\"stat-hours\"\n        >\n          <div className=\"flex items-center justify-between\">\n            <span className=\"text-[10px] uppercase font-bold tracking-wider text-gray-500\">Total Time</span>\n            <div className=\"text-lime-accent\">\n              <Clock className=\"h-3.5 w-3.5\" />\n            </div>\n          </div>\n          <div>\n            <span className=\"text-2xl font-mono font-bold text-white tracking-tight\">{stats.totalDurationHours}</span>\n            <span className=\"text-[10px] text-gray-500 ml-1 font-mono\">hrs</span>\n          </div>\n          <div className=\"text-[9px] font-mono text-gray-600 uppercase\">\n            Cardio duration\n          </div>\n          <div className=\"absolute bottom-0 left-0 right-0 h-[2px] bg-lime-accent/40 group-hover:bg-lime-accent transition-colors\" />\n        </div>\n\n        {/* Stat 3: Avg Pace */}\n        <div \n          className=\"bg-highdensity-panel p-4 flex flex-col justify-between h-28 relative group\"\n          id=\"stat-pace\"\n        >\n          <div className=\"flex items-center justify-between\">\n            <span className=\"text-[10px] uppercase font-bold tracking-wider text-gray-500\">Avg Pace</span>\n            <div className=\"text-lime-accent\">\n              <Activity className=\"h-3.5 w-3.5\" />\n            </div>\n          </div>\n          <div>\n            <span className=\"text-2xl font-mono font-bold text-white tracking-tight\">{stats.avgPace}</span>\n            <span className=\"text-[10px] text-gray-500 ml-1\">/km</span>\n          </div>\n          <div className=\"text-[9px] font-mono text-gray-600 uppercase\">\n            Averaged pace\n          </div>\n          <div className=\"absolute bottom-0 left-0 right-0 h-[2px] bg-lime-accent/40 group-hover:bg-lime-accent transition-colors\" />\n        </div>\n\n        {/* Stat 4: Avg HR */}\n        <div \n          className=\"bg-highdensity-panel p-4 flex flex-col justify-between h-28 relative group\"\n          id=\"stat-hr\"\n        >\n          <div className=\"flex items-center justify-between\">\n            <span className=\"text-[10px] uppercase font-bold tracking-wider text-gray-500\">Avg HR</span>\n            <div className=\"text-rose-500\">\n              <Heart className=\"h-3.5 w-3.5\" />\n            </div>\n          </div>\n          <div>\n            <span className=\"text-2xl font-mono font-bold text-white tracking-tight\">{stats.avgHr}</span>\n            <span className=\"text-[10px] text-gray-500 ml-1 font-mono\">bpm</span>\n          </div>\n          <div className=\"text-[9px] font-mono text-gray-600 uppercase\">\n            Mean heart rate\n          </div>\n          <div className=\"absolute bottom-0 left-0 right-0 h-[2px] bg-rose-500/40 group-hover:bg-rose-500 transition-colors\" />\n        </div>\n\n        {/* Stat 5: Total Activities */}\n        <div \n          className=\"bg-highdensity-panel p-4 flex flex-col justify-between h-28 col-span-2 lg:col-span-1 relative group\"\n          id=\"stat-activities\"\n        >\n          <div className=\"flex items-center justify-between\">\n            <span className=\"text-[10px] uppercase font-bold tracking-wider text-gray-500\">Sessions</span>\n            <div className=\"text-lime-accent\">\n              <Calendar className=\"h-3.5 w-3.5\" />\n            </div>\n          </div>\n          <div>\n            <span className=\"text-2xl font-mono font-bold text-white tracking-tight\">{stats.totalActivities}</span>\n            <span className=\"text-[10px] text-gray-500 ml-1 font-mono\">runs</span>\n          </div>\n          <div className=\"text-[9px] font-mono text-gray-600 uppercase\">\n            TCX Logs parsed\n          </div>\n          <div className=\"absolute bottom-0 left-0 right-0 h-[2px] bg-lime-accent/40 group-hover:bg-lime-accent transition-colors\" />\n        </div>\n\n      </div>\n\n      {/* Main Dashboard Layout: Chart & Recent Activities */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-5\">\n        \n        {/* Progress Chart (7/12 width on desktop) */}\n        <div className=\"lg:col-span-7 bg-[#0F1115] border border-white/10 rounded p-5 flex flex-col justify-between\">\n          <div>\n            <div className=\"flex items-center justify-between mb-4 border-b border-white/5 pb-3\">\n              <div>\n                <h3 className=\"text-xs font-bold uppercase tracking-widest text-gray-400\">Intensity Graph</h3>\n                <p className=\"text-[10px] text-gray-500 mt-0.5\">Last 5 activities: Distance (bar volume) vs Pace (cyan sequence)</p>\n              </div>\n              <div className=\"flex items-center gap-3 text-[9px] font-mono\">\n                <div className=\"flex items-center gap-1.5 text-lime-accent\">\n                  <span className=\"h-1.5 w-1.5 bg-lime-accent rounded-sm\"></span>\n                  KM\n                </div>\n                <div className=\"flex items-center gap-1.5 text-cyan-400\">\n                  <span className=\"h-1.5 w-1.5 bg-cyan-450 rounded-sm\"></span>\n                  PACE\n                </div>\n              </div>\n            </div>\n\n            {/* Custom SVG Responsive Chart */}\n            <div className=\"h-56 w-full relative pt-2\" id=\"svg-trend-chart\">\n              {chartData.length === 0 ? (\n                <div className=\"absolute inset-0 flex items-center justify-center text-gray-650 text-xs font-mono uppercase\">\n                  No activities registered. Upload TCX logs to stream.\n                </div>\n              ) : (\n                <svg className=\"w-full h-full overflow-visible\" viewBox=\"0 0 500 200\" preserveAspectRatio=\"none\">\n                  {/* Grid Lines */}\n                  <line x1=\"0\" y1=\"30\" x2=\"500\" y2=\"30\" stroke=\"rgba(255,255,255,0.03)\" strokeDasharray=\"3,3\" />\n                  <line x1=\"0\" y1=\"80\" x2=\"500\" y2=\"80\" stroke=\"rgba(255,255,255,0.03)\" strokeDasharray=\"3,3\" />\n                  <line x1=\"0\" y1=\"130\" x2=\"500\" y2=\"130\" stroke=\"rgba(255,255,255,0.03)\" strokeDasharray=\"3,3\" />\n                  <line x1=\"0\" y1=\"170\" x2=\"500\" y2=\"170\" stroke=\"rgba(255,255,255,0.1)\" />\n\n                  {/* Render Distance Bars & Pace Line */}\n                  {chartData.map((d, index) => {\n                    const step = 500 / 6;\n                    const x = step * (index + 0.8);\n                    \n                    // Bar calculations (distance)\n                    const barHeight = (d.distanceKm / maxDistance) * 140;\n                    const yBar = 170 - barHeight;\n\n                    // Line calculations (pace)\n                    const paceSecs = paceToSeconds(d.avgPace);\n                    const normalizedPace = (paceSecs - minPaceSecs) / (maxPaceSecs - minPaceSecs || 1);\n                    const yLine = 40 + (normalizedPace * 100);\n\n                    return (\n                      <g key={d.id} className=\"cursor-pointer\">\n                        {/* Interactive Bar */}\n                        <motion.rect\n                          x={x - 10}\n                          y={yBar}\n                          width=\"20\"\n                          height={barHeight}\n                          rx=\"1\"\n                          fill=\"url(#lime-grad)\"\n                          initial={{ scaleY: 0, originY: 1 }}\n                          animate={{ scaleY: 1 }}\n                          transition={{ delay: index * 0.05, duration: 0.3 }}\n                          onHoverStart={() => setHoveredIndex(index)}\n                          onHoverEnd={() => setHoveredIndex(null)}\n                          className=\"hover:opacity-85 transition-opacity\"\n                        />\n\n                        {/* Pace Dot */}\n                        <circle\n                          cx={x}\n                          cy={yLine}\n                          r=\"4\"\n                          fill=\"#22d3ee\"\n                          stroke=\"#0B0C0E\"\n                          strokeWidth=\"1.5\"\n                        />\n\n                        {/* Label Date */}\n                        <text\n                          x={x}\n                          y=\"188\"\n                          fill=\"#4b5563\"\n                          fontSize=\"8\"\n                          textAnchor=\"middle\"\n                          fontFamily=\"monospace\"\n                          fontWeight=\"bold\"\n                        >\n                          {new Date(d.date).toLocaleDateString(\'it-IT\', { day: \'2-digit\', month: \'short\' }).toUpperCase()}\n                        </text>\n\n                        {/* Label value of Distance */}\n                        <text\n                          x={x}\n                          y={yBar - 6}\n                          fill=\"#CCFF00\"\n                          fontSize=\"8\"\n                          fontWeight=\"bold\"\n                          fontFamily=\"monospace\"\n                          textAnchor=\"middle\"\n                        >\n                          {d.distanceKm.toFixed(1)}k\n                        </text>\n\n                        {/* Tooltip Overlay */}\n                        {hoveredIndex === index && (\n                          <g>\n                            <rect\n                              x={x < 250 ? x + 20 : x - 130}\n                              y=\"20\"\n                              width=\"120\"\n                              height=\"85\"\n                              rx=\"2\"\n                              fill=\"#07080A\"\n                              stroke=\"#CCFF00\"\n                              strokeWidth=\"1\"\n                            />\n                            <text x={x < 250 ? x + 30 : x - 120} y=\"38\" fill=\"#ffffff\" fontSize=\"9\" fontWeight=\"bold\" fontFamily=\"monospace\">\n                              {d.name.substring(0, 15).toUpperCase()}\n                            </text>\n                            <text x={x < 250 ? x + 30 : x - 120} y=\"54\" fill=\"#94a3b8\" fontSize=\"8\" fontFamily=\"monospace\">\n                              DIST: <tspan fill=\"#CCFF00\" fontWeight=\"bold\">{d.distanceKm} KM</tspan>\n                            </text>\n                            <text x={x < 250 ? x + 30 : x - 120} y=\"68\" fill=\"#94a3b8\" fontSize=\"8\" fontFamily=\"monospace\">\n                              PACE: <tspan fill=\"#22d3ee\" fontWeight=\"bold\">{d.avgPace}</tspan>\n                            </text>\n                            <text x={x < 250 ? x + 30 : x - 120} y=\"82\" fill=\"#94a3b8\" fontSize=\"8\" fontFamily=\"monospace\">\n                              DUR: {d.durationMin} MIN\n                            </text>\n                          </g>\n                        )}\n                      </g>\n                    );\n                  })}\n\n                  {/* Connected line between dots */}\n                  {chartData.length > 1 && (\n                    <path\n                      d={chartData.map((d, index) => {\n                        const step = 500 / 6;\n                        const x = step * (index + 0.8);\n                        const paceSecs = paceToSeconds(d.avgPace);\n                        const normalizedPace = (paceSecs - minPaceSecs) / (maxPaceSecs - minPaceSecs || 1);\n                        const yLine = 40 + (normalizedPace * 100);\n                        return `${index === 0 ? \'M\' : \'L\'} ${x} ${yLine}`;\n                      }).join(\' \')}\n                      fill=\"none\"\n                      stroke=\"#22d3ee\"\n                      strokeWidth=\"1.5\"\n                      strokeDasharray=\"2\"\n                      className=\"opacity-60 pointer-events-none\"\n                    />\n                  )}\n\n                  {/* Gradient definition */}\n                  <defs>\n                    <linearGradient id=\"lime-grad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                      <stop offset=\"0%\" stopColor=\"#CCFF00\" stopOpacity=\"0.8\" />\n                      <stop offset=\"100%\" stopColor=\"#CCFF00\" stopOpacity=\"0.1\" />\n                    </linearGradient>\n                  </defs>\n                </svg>\n              )}\n            </div>\n          </div>\n          \n          <div className=\"mt-2 pt-3 border-t border-white/5 flex justify-between items-center text-[10px] font-mono text-gray-550\">\n            <span>TCX telemetry streaming sequence active.</span>\n            <button \n              onClick={onNavigateToHistory}\n              className=\"text-lime-accent hover:underline font-bold uppercase tracking-wider flex items-center gap-0.5 transition-colors\"\n            >\n              All Logs\n              <ChevronRight className=\"h-3 w-3\" />\n            </button>\n          </div>\n        </div>\n\n        {/* Recent runs list (5/12 width on desktop) */}\n        <div className=\"lg:col-span-5 bg-[#0F1115] border border-white/10 rounded p-5 flex flex-col justify-between\">\n          <div>\n            <h3 className=\"text-xs font-bold uppercase tracking-widest text-gray-400 mb-4 border-b border-white/5 pb-3\">Recent Activities</h3>\n            <div className=\"space-y-2.5\">\n              {activities.slice(0, 4).map((act) => (\n                <div \n                  key={act.id} \n                  className=\"bg-black/30 border border-white/5 p-3 rounded flex items-center justify-between group hover:border-lime-accent/50 transition-all duration-150 cursor-pointer\"\n                  onClick={onNavigateToHistory}\n                >\n                  <div className=\"flex items-center gap-3\">\n                    <div className=\"h-8 w-8 bg-lime-accent/10 border border-lime-accent/20 text-lime-accent flex items-center justify-center font-mono font-bold text-xs rounded-sm\">\n                      {act.distanceKm.toFixed(0)}\n                      <span className=\"text-[8px] font-normal uppercase\">k</span>\n                    </div>\n                    <div className=\"min-w-0\">\n                      <h4 className=\"text-xs font-bold text-white uppercase tracking-tight truncate group-hover:text-lime-accent transition-colors\">\n                        {act.name}\n                      </h4>\n                      <p className=\"text-[9px] font-mono text-gray-500 mt-0.5 uppercase\">\n                        {new Date(act.date).toLocaleDateString(\'it-IT\', { day: \'numeric\', month: \'short\' })} \342\200\242 {act.durationMin} MIN\n                      </p>\n                    </div>\n                  </div>\n                  <div className=\"text-right font-mono\">\n                    <p className=\"text-xs font-bold text-white\">{act.avgPace}</p>\n                    <p className=\"text-[9px] text-gray-500 mt-0.5 uppercase\">/KM</p>\n                  </div>\n                </div>\n              ))}\n\n              {activities.length === 0 && (\n                <div className=\"text-center py-10 text-gray-650 text-xs font-mono uppercase\">\n                  No telemetry logged.\n                </div>\n              )}\n            </div>\n          </div>\n\n          <button \n            onClick={onNavigateToHistory}\n            className=\"w-full mt-4 bg-black/50 border border-white/10 hover:border-white/20 text-slate-300 text-[10px] font-bold uppercase tracking-wider py-2 rounded transition-colors flex items-center justify-center gap-1\"\n          >\n            Manage Activities\n            <ChevronRight className=\"h-3 w-3\" />\n          </button>\n        </div>\n\n      </div>\n\n      {/* Advice Card - Styled to match High Density System terminal */}\n      <div className=\"bg-[#0F1115] border border-white/10 p-5 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 rounded\">\n        <div className=\"flex gap-4 items-start\">\n          <div className=\"p-2.5 bg-lime-accent/10 text-lime-accent rounded-sm border border-lime-accent/20 shrink-0\">\n            <Cpu className=\"h-5 w-5\" />\n          </div>\n          <div>\n            <h4 className=\"text-xs font-bold uppercase tracking-widest text-white\">Daily Advisory System</h4>\n            <p className=\"text-xs text-slate-300 mt-1 max-w-3xl leading-relaxed font-sans\">\n              Analisi biometrica: frequenza cardiaca media stabile a <span className=\"text-lime-accent font-bold font-mono\">{stats.avgHr} bpm</span>. In base ai volumi TCX elaborati, si consiglia un ciclo di corsa a bassa intensit\303\240 (Zona 2) per ottimizzare la gittata sistolica periferica senza incrementare l\'indice di stress neurale.\n            </p>\n          </div>\n        </div>\n      </div>\n\n    </div>\n  );\n}"
      }
      num_matches: 1
    }
  }
}
