        }
        lines {
          text: "  const maxDistance = Math.max(...chartData.map(d => d.distanceKm), 10);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  // Convert \"MM:SS\" pace to seconds for charting"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  const paceToSeconds = (paceStr: string) => {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    if (!paceStr || !paceStr.includes(\':\')) return 300; // default 5:00"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    const [m, s] = paceStr.split(\':\').map(Number);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    return m * 60 + s;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
