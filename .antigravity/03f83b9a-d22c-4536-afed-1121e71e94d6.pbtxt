          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          fill=\"#34d399\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          fontSize=\"9\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          fontWeight=\"bold\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          textAnchor=\"middle\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                        >"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          {d.distanceKm}k"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                        </text>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
