          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          fontFamily=\"monospace\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                        >"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          {new Date(d.date).toLocaleDateString(\'it-IT\', { day: \'2-digit\', month: \'short\' })}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                        </text>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                        {/* Label value of Distance */}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                        <text"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          x={x}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
