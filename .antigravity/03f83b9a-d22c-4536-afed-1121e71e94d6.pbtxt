    replacement_infos {
      original_chunk {
        target_content: "import express from \'express\';\nimport path from \'path\';\nimport multer from \'multer\';\nimport dotenv from \'dotenv\';\nimport { createServer as createViteServer } from \'vite\';\nimport { GoogleGenAI } from \'@google/genai\';\nimport { parseTcx } from \'./server/tcxParser.js\';\nimport {\n  getActivities,\n  saveActivities,\n  getChatHistory,\n  saveChatHistory,\n  clearChatHistory,\n  getTrainingPlans,\n  saveTrainingPlan,\n  initializeDb\n} from \'./server/db.js\';"
        replacement_content: "import express from \'express\';\nimport path from \'path\';\nimport multer from \'multer\';\nimport dotenv from \'dotenv\';\nimport fs from \'fs\';\nimport { createServer as createViteServer } from \'vite\';\nimport { GoogleGenAI } from \'@google/genai\';\nimport { parseTcx } from \'./server/tcxParser.js\';\nimport {\n  getActivities,\n  saveActivities,\n  getChatHistory,\n  saveChatHistory,\n  clearChatHistory,\n  getTrainingPlans,\n  saveTrainingPlan,\n  initializeDb,\n  TCX_DIR\n} from \'./server/db.js\';"
      }
      num_matches: 1
    }
    replacement_infos {
      original_chunk {
        target_content: "app.post(\'/api/upload-tcx\', upload.single(\'file\'), async (req, res) => {\n  try {\n    if (!req.file) {\n      return res.status(400).json({ error: \'Nessun file caricato\' });\n    }\n\n    const fileContent = req.file.buffer.toString(\'utf8\');\n    if (!fileContent.includes(\'<TrainingCenterDatabase\')) {\n      return res.status(400).json({ error: \'Il file caricato non sembra un file TCX valido.\' });\n    }\n\n    const newActivity = parseTcx(fileContent);\n\n    // Save to list\n    const activities = await getActivities();\n    activities.push(newActivity);\n    await saveActivities(activities);\n\n    res.json({\n      success: true,\n      activity: newActivity,\n    });\n  } catch (error: any) {\n    console.error(\'Error parsing TCX:\', error);\n    res.status(500).json({ error: `Impossibile analizzare il file TCX: ${error.message}` });\n  }\n});"
        replacement_content: "app.post(\'/api/upload-tcx\', upload.single(\'file\'), async (req, res) => {\n  try {\n    if (!req.file) {\n      return res.status(400).json({ error: \'Nessun file caricato\' });\n    }\n\n    const fileContent = req.file.buffer.toString(\'utf8\');\n    if (!fileContent.includes(\'<TrainingCenterDatabase\')) {\n      return res.status(400).json({ error: \'Il file caricato non sembra un file TCX valido.\' });\n    }\n\n    // Save physical TCX file to the TCX folder\n    const filename = `uploaded_${Date.now()}.tcx`;\n    const filePath = path.join(TCX_DIR, filename);\n    await fs.promises.writeFile(filePath, fileContent, \'utf8\');\n\n    // Run standard DB parsing to synchronize everything beautifully\n    await initializeDb();\n\n    // Find the newly added activity\n    const activities = await getActivities();\n    const sorted = [...activities].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());\n    const newActivity = sorted[0] || parseTcx(fileContent);\n\n    res.json({\n      success: true,\n      activity: newActivity,\n    });\n  } catch (error: any) {\n    console.error(\'Error parsing TCX:\', error);\n    res.status(500).json({ error: `Impossibile analizzare il file TCX: ${error.message}` });\n  }\n});"
      }
      num_matches: 1
    }
