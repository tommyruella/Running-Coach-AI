          text: "                                {act.laps && act.laps.map((lap) => {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                                  // calculate pace for the lap"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                                  const lapMin = lap.durationSec / 60;"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                                  const paceSeconds = lap.distanceKm > 0 ? (lap.durationSec / lap.distanceKm) : 0;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                                  let lapPaceStr = \'--:--\';"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                                  if (paceSeconds > 0) {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                                    const min = Math.floor(paceSeconds / 60);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                                    const sec = Math.round(paceSeconds % 60);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                                    lapPaceStr = `${min.toString().padStart(2, \'0\')}:${sec.toString().padStart(2, \'0\')}`;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                                  }"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                                  return ("
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                                    <tr key={lap.lapIndex} className=\"border-b border-slate-850 hover:bg-slate-900/20 last:border-0 transition-colors\">"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                                      <td className=\"py-2 px-4 text-center font-bold text-slate-400 font-mono bg-slate-900/20\">{lap.lapIndex}</td>"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                                      <td className=\"py-2 px-4 font-semibold text-white font-mono\">{lap.distanceKm.toFixed(2)} km</td>"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                                      <td className=\"py-2 px-4 text-slate-300 font-mono\">{formatDuration(lap.durationSec)}</td>"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                                      <td className=\"py-2 px-4 text-cyan-400 font-bold font-mono\">{lapPaceStr}/km</td>"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                                      <td className=\"py-2 px-4 text-rose-400 font-mono\">{lap.avgHeartRate ? `${lap.avgHeartRate} bpm` : \'--\'}</td>"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                                      <td className=\"py-2 px-4 text-slate-300 font-mono\">{lap.avgCadence ? `${lap.avgCadence} ppm` : \'--\'}</td>"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                                    <tr key={lap.lapIndex} className=\"border-b border-white/5 hover:bg-white/5 last:border-0 transition-colors\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                                      <td className=\"py-2 px-3 text-center font-bold text-gray-500 bg-black/20\">{lap.lapIndex}</td>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                                      <td className=\"py-2 px-3 font-bold text-white\">{lap.distanceKm.toFixed(2)} KM</td>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                                      <td className=\"py-2 px-3 text-slate-300\">{formatDuration(lap.durationSec)}</td>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                                      <td className=\"py-2 px-3 text-cyan-400 font-bold\">{lapPaceStr}/KM</td>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                                      <td className=\"py-2 px-3 text-rose-500 font-bold\">{lap.avgHeartRate ? `${lap.avgHeartRate}` : \'--\'}</td>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                                      <td className=\"py-2 px-3 text-slate-400\">{lap.avgCadence ? `${lap.avgCadence}` : \'--\'}</td>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                                    </tr>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                                  );"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                                })}"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                                {(!act.laps || act.laps.length === 0) && ("
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                                  <tr>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                                    <td colSpan={6} className=\"py-8 text-center text-slate-500 italic\">"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                                      Nessun dettaglio giro registrato nel file."
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                                    <td colSpan={6} className=\"py-8 text-center text-gray-650 uppercase text-[10px] font-mono italic\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                                      No detailed split intervals compiled."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                                    </td>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                                  </tr>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                                )}"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                              </tbody>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                            </table>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                          </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                        </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                    </motion.div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                  )}"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                </AnimatePresence>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            );"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "          })}"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "          {activities.length === 0 && ("
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            <div className=\"text-center py-12 bg-slate-900/30 border border-slate-800 rounded-2xl text-slate-400 text-sm\">"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "              Non \303\250 ancora presente alcun allenamento registrato. Sincronizza il tuo primo file TCX per iniziare!"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "            <div className=\"text-center py-12 bg-[#0F1115] border border-white/10 rounded text-gray-500 text-xs font-mono uppercase\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              No sessions found. Sync a .tcx telemetry log sequence to initialize index databases."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "          )}"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    </div>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  );"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
      }
    }
    instruction: "Apply High Density styling (colors, layout density, fonts, borders, upload state, and table borders) to History component"
    replacement_infos {
      original_chunk {
        target_content: "  return (\n    <div className=\"space-y-8\" id=\"history-tab\">\n      \n      {/* Page Title */}\n      <div>\n        <h2 className=\"text-2xl font-bold tracking-tight text-white flex items-center gap-2\">\n          <Calendar className=\"h-6 w-6 text-emerald-400\" />\n          Storico Allenamenti\n        </h2>\n        <p className=\"text-slate-400 text-sm mt-1\">\n          Carica file TCX per sincronizzare le corse o consulta lo storico completo dei tuoi giri e tempi.\n        </p>\n      </div>\n\n      {/* Upload Zone */}\n      <div \n        onDragEnter={handleDrag}\n        onDragOver={handleDrag}\n        onDragLeave={handleDrag}\n        onDrop={handleDrop}\n        className={`border-2 border-dashed rounded-2xl p-8 text-center transition-all duration-200 relative overflow-hidden flex flex-col items-center justify-center cursor-pointer ${\n          dragActive \n            ? \'border-emerald-500 bg-emerald-500/5\' \n            : \'border-slate-800 bg-slate-900/20 hover:border-slate-700/80 hover:bg-slate-900/30\'\n        }`}\n        onClick={triggerFileInput}\n        id=\"tcx-upload-zone\"\n      >\n        <input \n          ref={fileInputRef}\n          type=\"file\"\n          accept=\".tcx\"\n          onChange={handleFileChange}\n          className=\"hidden\"\n        />\n\n        <div className=\"space-y-4 max-w-sm\">\n          {/* Icons container */}\n          <div className=\"mx-auto h-12 w-12 rounded-2xl bg-emerald-500/10 text-emerald-400 flex items-center justify-center shadow-lg\">\n            {isUploading ? (\n              <svg className=\"animate-spin h-5 w-5 text-emerald-400\" fill=\"none\" viewBox=\"0 0 24 24\">\n                <circle className=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" strokeWidth=\"4\"></circle>\n                <path className=\"opacity-75\" fill=\"currentColor\" d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\"></path>\n              </svg>\n            ) : (\n              <UploadCloud className=\"h-6 w-6\" />\n            )}\n          </div>\n\n          <div className=\"space-y-1\">\n            <p className=\"text-sm font-semibold text-white\">\n              {isUploading ? \'Analisi del file in corso...\' : \'Trascina qui il tuo file .tcx\'}\n            </p>\n            <p className=\"text-xs text-slate-400 leading-relaxed\">\n              oppure <span className=\"text-emerald-400 font-bold underline hover:text-emerald-300\">clicca per sfogliare</span> il computer (file TCX Garmin/Strava)\n            </p>\n          </div>\n        </div>\n\n        {/* Error / Success Banners */}\n        <AnimatePresence>\n          {uploadError && (\n            <motion.div \n              initial={{ opacity: 0, y: 10 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, y: 10 }}\n              className=\"absolute bottom-3 left-4 right-4 bg-rose-500/10 border border-rose-500/20 rounded-xl px-4 py-2.5 flex items-center gap-2.5 text-xs text-rose-400 text-left\"\n            >\n              <AlertCircle className=\"h-4 w-4 shrink-0\" />\n              <span>{uploadError}</span>\n            </motion.div>\n          )}\n\n          {uploadSuccess && (\n            <motion.div \n              initial={{ opacity: 0, y: 10 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, y: 10 }}\n              className=\"absolute bottom-3 left-4 right-4 bg-emerald-500/10 border border-emerald-500/20 rounded-xl px-4 py-2.5 flex items-center gap-2.5 text-xs text-emerald-400 text-left\"\n            >\n              <FileCheck className=\"h-4 w-4 shrink-0\" />\n              <span>{uploadSuccess}</span>\n            </motion.div>\n          )}\n        </AnimatePresence>\n      </div>\n\n      {/* History List */}\n      <div className=\"space-y-4\">\n        <div className=\"flex items-center justify-between\">\n          <h3 className=\"text-sm font-semibold text-slate-400\">Tutte le Sessioni ({activities.length})</h3>\n          <span className=\"text-[10px] text-slate-500\">Clicca su un allenamento per i dettagli dei giri (splits)</span>\n        </div>\n\n        <div className=\"space-y-3\" id=\"activities-history-list\">\n          {activities.map((act) => {\n            const isExpanded = expandedActivityId === act.id;\n            const dateStr = new Date(act.date).toLocaleDateString(\'it-IT\', {\n              weekday: \'short\',\n              day: \'numeric\',\n              month: \'long\',\n              year: \'numeric\'\n            });\n            const timeStr = new Date(act.date).toLocaleTimeString(\'it-IT\', {\n              hour: \'2-digit\',\n              minute: \'2-digit\'\n            });\n\n            return (\n              <div \n                key={act.id}\n                className={`bg-slate-900 border rounded-2xl overflow-hidden transition-all duration-200 ${\n                  isExpanded ? \'border-emerald-500/40 shadow-xl\' : \'border-slate-800 hover:border-slate-700/80\'\n                }`}\n              >\n                {/* Main Header Item */}\n                <div \n                  onClick={() => toggleExpand(act.id)}\n                  className=\"p-4 md:p-5 flex items-center justify-between gap-4 cursor-pointer select-none\"\n                >\n                  <div className=\"flex items-center gap-4 min-w-0\">\n                    {/* Badge Distance */}\n                    <div className=\"h-12 w-12 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 flex flex-col items-center justify-center shrink-0\">\n                      <span className=\"text-sm font-bold tracking-tight font-mono\">{act.distanceKm.toFixed(1)}</span>\n                      <span className=\"text-[8px] font-medium uppercase tracking-wider -mt-1\">km</span>\n                    </div>\n\n                    <div className=\"min-w-0\">\n                      <h4 className=\"text-sm font-bold text-white group-hover:text-emerald-400 transition-colors truncate\">\n                        {act.name}\n                      </h4>\n                      <p className=\"text-[10px] text-slate-500 flex items-center gap-1.5 mt-1 font-medium\">\n                        <span>{dateStr}</span>\n                        <span>\342\200\242</span>\n                        <span>{timeStr}</span>\n                        {act.deviceModel && (\n                          <>\n                            <span>\342\200\242</span>\n                            <span className=\"flex items-center gap-0.5\">\n                              <Smartphone className=\"h-3 w-3\" />\n                              {act.deviceModel}\n                            </span>\n                          </>\n                        )}\n                      </p>\n                    </div>\n                  </div>\n\n                  {/* Quick Stats Grid */}\n                  <div className=\"flex items-center gap-6\">\n                    <div className=\"hidden sm:grid grid-cols-3 gap-6 text-right\">\n                      <div>\n                        <span className=\"text-[10px] text-slate-500 uppercase font-bold tracking-wider block\">Passo</span>\n                        <span className=\"text-xs font-semibold text-white font-mono mt-0.5 block\">{act.avgPace}</span>\n                      </div>\n                      <div>\n                        <span className=\"text-[10px] text-slate-500 uppercase font-bold tracking-wider block\">Durata</span>\n                        <span className=\"text-xs font-semibold text-white font-mono mt-0.5 block\">{act.durationMin} min</span>\n                      </div>\n                      <div>\n                        <span className=\"text-[10px] text-slate-500 uppercase font-bold tracking-wider block\">Zone HR</span>\n                        <span className=\"text-xs font-semibold text-rose-400 font-mono mt-0.5 block\">\n                          {act.avgHeartRate ? `${act.avgHeartRate} bpm` : \'--\'}\n                        </span>\n                      </div>\n                    </div>\n\n                    {/* Expand Chevron */}\n                    <div className=\"text-slate-400 p-1.5 hover:bg-slate-800 rounded-lg transition-colors\">\n                      {isExpanded ? <ChevronUp className=\"h-4.5 w-4.5\" /> : <ChevronDown className=\"h-4.5 w-4.5\" />}\n                    </div>\n                  </div>\n                </div>\n\n                {/* Expanded Details Drawer */}\n                <AnimatePresence>\n                  {isExpanded && (\n                    <motion.div\n                      initial={{ height: 0, opacity: 0 }}\n                      animate={{ height: \'auto\', opacity: 1 }}\n                      exit={{ height: 0, opacity: 0 }}\n                      transition={{ duration: 0.25 }}\n                      className=\"border-t border-slate-800 bg-slate-950/40\"\n                    >\n                      <div className=\"p-5 grid grid-cols-1 lg:grid-cols-3 gap-6\">\n                        \n                        {/* Summary & Note columns */}\n                        <div className=\"space-y-4\">\n                          <h5 className=\"text-xs font-bold text-slate-400 uppercase tracking-wider\">Note & Dispositivo</h5>\n                          \n                          <div className=\"bg-slate-900 border border-slate-800/80 rounded-xl p-3.5 space-y-3 text-xs\">\n                            {act.notes ? (\n                              <p className=\"text-slate-300 italic leading-relaxed\">{act.notes}</p>\n                            ) : (\n                              <p className=\"text-slate-500\">Nessuna nota inserita per questa attivit\303\240.</p>\n                            )}\n\n                            <div className=\"pt-2 border-t border-slate-800 flex items-center justify-between text-[11px] text-slate-400\">\n                              <span className=\"flex items-center gap-1\">\n                                <Smartphone className=\"h-3.5 w-3.5 text-emerald-400\" />\n                                {act.deviceBrand || \'Garmin\'} {act.deviceModel}\n                              </span>\n                              <span className=\"capitalize font-medium text-emerald-400\">{act.sport || \'Corsa\'}</span>\n                            </div>\n                          </div>\n\n                          {/* Secondary Metrics */}\n                          <div className=\"grid grid-cols-2 gap-3\">\n                            <div className=\"bg-slate-900 border border-slate-800/50 p-3 rounded-xl\">\n                              <span className=\"text-[10px] text-slate-500 flex items-center gap-1 font-bold uppercase tracking-wider\">\n                                <Flame className=\"h-3.5 w-3.5 text-amber-500\" />\n                                Calorie\n                              </span>\n                              <span className=\"text-sm font-bold text-white block mt-1 font-mono\">{act.calories} <span className=\"text-[10px] font-normal text-slate-400\">kcal</span></span>\n                            </div>\n                            <div className=\"bg-slate-900 border border-slate-800/50 p-3 rounded-xl\">\n                              <span className=\"text-[10px] text-slate-500 flex items-center gap-1 font-bold uppercase tracking-wider\">\n                                <Activity className=\"h-3.5 w-3.5 text-cyan-400\" />\n                                Cadenza Media\n                              </span>\n                              <span className=\"text-sm font-bold text-white block mt-1 font-mono\">{act.avgCadence || \'--\'} <span className=\"text-[10px] font-normal text-slate-400\">ppm</span></span>\n                            </div>\n                          </div>\n                        </div>\n\n                        {/* Laps Splits column (2/3 width on desktop) */}\n                        <div className=\"lg:col-span-2 space-y-4\">\n                          <div className=\"flex items-center justify-between\">\n                            <h5 className=\"text-xs font-bold text-slate-400 uppercase tracking-wider flex items-center gap-1\">\n                              <Layers className=\"h-3.5 w-3.5 text-emerald-400\" />\n                              Dettagli Giri (Splits)\n                            </h5>\n                            <span className=\"text-[9px] text-slate-500\">Totale {act.laps?.length || 0} giri</span>\n                          </div>\n\n                          <div className=\"overflow-x-auto border border-slate-850 bg-slate-900/40 rounded-xl\">\n                            <table className=\"w-full text-left border-collapse text-xs\">\n                              <thead>\n                                <tr className=\"border-b border-slate-800 text-[10px] text-slate-500 uppercase tracking-wider font-bold bg-slate-900/60\">\n                                  <th className=\"py-2.5 px-4 text-center w-12\">Giro</th>\n                                  <th className=\"py-2.5 px-4\">Distanza</th>\n                                  <th className=\"py-2.5 px-4\">Tempo</th>\n                                  <th className=\"py-2.5 px-4\">Passo</th>\n                                  <th className=\"py-2.5 px-4\">FC Media</th>\n                                  <th className=\"py-2.5 px-4\">Cadenza</th>\n                                </tr>\n                              </thead>\n                              <tbody>\n                                {act.laps && act.laps.map((lap) => {\n                                  // calculate pace for the lap\n                                  const lapMin = lap.durationSec / 60;\n                                  const paceSeconds = lap.distanceKm > 0 ? (lap.durationSec / lap.distanceKm) : 0;\n                                  let lapPaceStr = \'--:--\';\n                                  if (paceSeconds > 0) {\n                                    const min = Math.floor(paceSeconds / 60);\n                                    const sec = Math.round(paceSeconds % 60);\n                                    lapPaceStr = `${min.toString().padStart(2, \'0\')}:${sec.toString().padStart(2, \'0\')}`;\n                                  }\n\n                                  return (\n                                    <tr key={lap.lapIndex} className=\"border-b border-slate-850 hover:bg-slate-900/20 last:border-0 transition-colors\">\n                                      <td className=\"py-2 px-4 text-center font-bold text-slate-400 font-mono bg-slate-900/20\">{lap.lapIndex}</td>\n                                      <td className=\"py-2 px-4 font-semibold text-white font-mono\">{lap.distanceKm.toFixed(2)} km</td>\n                                      <td className=\"py-2 px-4 text-slate-300 font-mono\">{formatDuration(lap.durationSec)}</td>\n                                      <td className=\"py-2 px-4 text-cyan-400 font-bold font-mono\">{lapPaceStr}/km</td>\n                                      <td className=\"py-2 px-4 text-rose-400 font-mono\">{lap.avgHeartRate ? `${lap.avgHeartRate} bpm` : \'--\'}</td>\n                                      <td className=\"py-2 px-4 text-slate-300 font-mono\">{lap.avgCadence ? `${lap.avgCadence} ppm` : \'--\'}</td>\n                                    </tr>\n                                  );\n                                })}\n\n                                {(!act.laps || act.laps.length === 0) && (\n                                  <tr>\n                                    <td colSpan={6} className=\"py-8 text-center text-slate-500 italic\">\n                                      Nessun dettaglio giro registrato nel file.\n                                    </td>\n                                  </tr>\n                                )}\n                              </tbody>\n                            </table>\n                          </div>\n                        </div>\n\n                      </div>\n                    </motion.div>\n                  )}\n                </AnimatePresence>\n              </div>\n            );\n          })}\n\n          {activities.length === 0 && (\n            <div className=\"text-center py-12 bg-slate-900/30 border border-slate-800 rounded-2xl text-slate-400 text-sm\">\n              Non \303\250 ancora presente alcun allenamento registrato. Sincronizza il tuo primo file TCX per iniziare!\n            </div>\n          )}\n        </div>\n      </div>"
        replacement_content: "  return (\n    <div className=\"space-y-6\" id=\"history-tab\">\n      \n      {/* High Density Header Section */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-white/5 pb-4\">\n        <div>\n          <h2 className=\"text-lg font-bold uppercase tracking-wider text-white flex items-center gap-2\">\n            <Calendar className=\"h-5 w-5 text-lime-accent\" />\n            Telemetry & Activity Logs\n          </h2>\n          <p className=\"text-gray-500 text-xs mt-0.5\">\n            Synchronize training sessions via .tcx telemetry upload and audit performance splits.\n          </p>\n        </div>\n      </div>\n\n      {/* Upload Zone - High Density Box */}\n      <div \n        onDragEnter={handleDrag}\n        onDragOver={handleDrag}\n        onDragLeave={handleDrag}\n        onDrop={handleDrop}\n        className={`border border-dashed rounded p-6 text-center transition-all duration-150 relative overflow-hidden flex flex-col items-center justify-center cursor-pointer ${\n          dragActive \n            ? \'border-lime-accent bg-lime-accent/5\' \n            : \'border-white/10 bg-[#0F1115] hover:border-lime-accent/50 hover:bg-[#0F1115]/80\'\n        }`}\n        onClick={triggerFileInput}\n        id=\"tcx-upload-zone\"\n      >\n        <input \n          ref={fileInputRef}\n          type=\"file\"\n          accept=\".tcx\"\n          onChange={handleFileChange}\n          className=\"hidden\"\n        />\n\n        <div className=\"space-y-3.5 max-w-sm py-2\">\n          {/* Icons container */}\n          <div className=\"mx-auto h-10 w-10 rounded-sm bg-lime-accent/10 border border-lime-accent/20 text-lime-accent flex items-center justify-center shadow-md\">\n            {isUploading ? (\n              <svg className=\"animate-spin h-5 w-5 text-lime-accent\" fill=\"none\" viewBox=\"0 0 24 24\">\n                <circle className=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" strokeWidth=\"4\"></circle>\n                <path className=\"opacity-75\" fill=\"currentColor\" d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\"></path>\n              </svg>\n            ) : (\n              <UploadCloud className=\"h-5 w-5\" />\n            )}\n          </div>\n\n          <div className=\"space-y-1\">\n            <p className=\"text-xs font-mono uppercase font-bold tracking-wider text-white\">\n              {isUploading ? \'Ingesting telemetry streams...\' : \'Drop .tcx log sequence here\'}\n            </p>\n            <p className=\"text-[10px] text-gray-500 font-sans\">\n              or <span className=\"text-lime-accent font-bold underline\">click to navigate storage</span> (Garmin / Strava XML logs)\n            </p>\n          </div>\n        </div>\n\n        {/* Flat alerts for High Density design */}\n        <AnimatePresence>\n          {uploadError && (\n            <motion.div \n              initial={{ opacity: 0, y: 5 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, y: 5 }}\n              className=\"absolute bottom-2 left-2 right-2 bg-rose-500/10 border-l-2 border-rose-500 rounded-sm px-3 py-2 flex items-center gap-2 text-[10px] text-rose-400 font-mono uppercase text-left\"\n            >\n              <AlertCircle className=\"h-3.5 w-3.5 shrink-0\" />\n              <span>FAIL: {uploadError}</span>\n            </motion.div>\n          )}\n\n          {uploadSuccess && (\n            <motion.div \n              initial={{ opacity: 0, y: 5 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, y: 5 }}\n              className=\"absolute bottom-2 left-2 right-2 bg-lime-accent/10 border-l-2 border-lime-accent rounded-sm px-3 py-2 flex items-center gap-2 text-[10px] text-lime-accent font-mono uppercase text-left\"\n            >\n              <FileCheck className=\"h-3.5 w-3.5 shrink-0\" />\n              <span>SUCCESS: {uploadSuccess}</span>\n            </motion.div>\n          )}\n        </AnimatePresence>\n      </div>\n\n      {/* History List */}\n      <div className=\"space-y-3\">\n        <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n          <h3 className=\"text-xs font-bold uppercase tracking-widest text-gray-400\">Recorded Sessions ({activities.length})</h3>\n          <span className=\"text-[9px] font-mono uppercase text-gray-600\">Select card to query split records</span>\n        </div>\n\n        <div className=\"space-y-2\" id=\"activities-history-list\">\n          {activities.map((act) => {\n            const isExpanded = expandedActivityId === act.id;\n            const dateStr = new Date(act.date).toLocaleDateString(\'it-IT\', {\n              weekday: \'short\',\n              day: \'numeric\',\n              month: \'short\',\n              year: \'numeric\'\n            }).toUpperCase();\n            const timeStr = new Date(act.date).toLocaleTimeString(\'it-IT\', {\n              hour: \'2-digit\',\n              minute: \'2-digit\'\n            });\n\n            return (\n              <div \n                key={act.id}\n                className={`bg-[#0F1115] border rounded overflow-hidden transition-all duration-150 ${\n                  isExpanded ? \'border-lime-accent shadow-2xl\' : \'border-white/10 hover:border-white/20\'\n                }`}\n              >\n                {/* Main Header Item */}\n                <div \n                  onClick={() => toggleExpand(act.id)}\n                  className=\"p-3.5 flex items-center justify-between gap-4 cursor-pointer select-none\"\n                >\n                  <div className=\"flex items-center gap-3.5 min-w-0\">\n                    {/* Badge Distance */}\n                    <div className=\"h-10 w-10 rounded-sm bg-lime-accent/10 border border-lime-accent/20 text-lime-accent flex flex-col items-center justify-center shrink-0\">\n                      <span className=\"text-sm font-bold tracking-tight font-mono leading-none\">{act.distanceKm.toFixed(1)}</span>\n                      <span className=\"text-[7px] font-bold uppercase tracking-wider mt-0.5\">km</span>\n                    </div>\n\n                    <div className=\"min-w-0\">\n                      <h4 className=\"text-xs font-bold text-white uppercase tracking-tight group-hover:text-lime-accent truncate\">\n                        {act.name}\n                      </h4>\n                      <p className=\"text-[9px] font-mono text-gray-500 flex flex-wrap items-center gap-1.5 mt-1 uppercase tracking-wider font-semibold\">\n                        <span>{dateStr}</span>\n                        <span>\342\200\242</span>\n                        <span>{timeStr}</span>\n                        {act.deviceModel && (\n                          <>\n                            <span>\342\200\242</span>\n                            <span className=\"flex items-center gap-0.5\">\n                              <Smartphone className=\"h-3 w-3\" />\n                              {act.deviceModel.toUpperCase()}\n                            </span>\n                          </>\n                        )}\n                      </p>\n                    </div>\n                  </div>\n\n                  {/* Quick Stats Grid */}\n                  <div className=\"flex items-center gap-4\">\n                    <div className=\"hidden sm:grid grid-cols-3 gap-4 text-right font-mono uppercase\">\n                      <div>\n                        <span className=\"text-[8px] text-gray-500 font-bold tracking-widest block\">PACE</span>\n                        <span className=\"text-xs font-bold text-white mt-0.5 block\">{act.avgPace}</span>\n                      </div>\n                      <div>\n                        <span className=\"text-[8px] text-gray-500 font-bold tracking-widest block\">DURATION</span>\n                        <span className=\"text-xs font-bold text-white mt-0.5 block\">{act.durationMin}M</span>\n                      </div>\n                      <div>\n                        <span className=\"text-[8px] text-gray-500 font-bold tracking-widest block\">HR ZONE</span>\n                        <span className=\"text-xs font-bold text-rose-450 text-rose-500 mt-0.5 block\">\n                          {act.avgHeartRate ? `${act.avgHeartRate}` : \'--\'}\n                        </span>\n                      </div>\n                    </div>\n\n                    {/* Expand Chevron */}\n                    <div className=\"text-gray-500 p-1 hover:bg-white/5 rounded transition-colors\">\n                      {isExpanded ? <ChevronUp className=\"h-4 w-4\" /> : <ChevronDown className=\"h-4 w-4\" />}\n                    </div>\n                  </div>\n                </div>\n\n                {/* Expanded Details Drawer */}\n                <AnimatePresence>\n                  {isExpanded && (\n                    <motion.div\n                      initial={{ height: 0, opacity: 0 }}\n                      animate={{ height: \'auto\', opacity: 1 }}\n                      exit={{ height: 0, opacity: 0 }}\n                      transition={{ duration: 0.15 }}\n                      className=\"border-t border-white/5 bg-black/40\"\n                    >\n                      <div className=\"p-4 grid grid-cols-1 lg:grid-cols-3 gap-5\">\n                        \n                        {/* Summary & Note columns */}\n                        <div className=\"space-y-3.5\">\n                          <h5 className=\"text-[9px] font-bold text-gray-400 uppercase tracking-widest\">Metadata & Telemetry</h5>\n                          \n                          <div className=\"bg-[#0F1115] border border-white/5 rounded p-3.5 space-y-3 text-xs\">\n                            {act.notes ? (\n                              <p className=\"text-slate-300 italic leading-relaxed font-sans\">{act.notes}</p>\n                            ) : (\n                              <p className=\"text-gray-500 font-mono uppercase text-[10px]\">No run metadata recorded.</p>\n                            )}\n\n                            <div className=\"pt-2 border-t border-white/5 flex items-center justify-between text-[10px] font-mono uppercase text-gray-400\">\n                              <span className=\"flex items-center gap-1\">\n                                <Smartphone className=\"h-3 w-3 text-lime-accent\" />\n                                {act.deviceBrand || \'Garmin\'} {act.deviceModel}\n                              </span>\n                              <span className=\"font-bold text-lime-accent\">{act.sport || \'RUN\'}</span>\n                            </div>\n                          </div>\n\n                          {/* Secondary Metrics */}\n                          <div className=\"grid grid-cols-2 gap-2.5\">\n                            <div className=\"bg-[#0F1115] border border-white/5 p-3 rounded\">\n                              <span className=\"text-[8px] text-gray-500 flex items-center gap-1 font-bold uppercase tracking-widest font-mono\">\n                                <Flame className=\"h-3 w-3 text-amber-500\" />\n                                Calories\n                              </span>\n                              <span className=\"text-sm font-bold text-white block mt-1 font-mono\">{act.calories} <span className=\"text-[9px] font-normal text-gray-500 uppercase\">kcal</span></span>\n                            </div>\n                            <div className=\"bg-[#0F1115] border border-white/5 p-3 rounded\">\n                              <span className=\"text-[8px] text-gray-500 flex items-center gap-1 font-bold uppercase tracking-widest font-mono\">\n                                <Activity className=\"h-3 w-3 text-cyan-400\" />\n                                Cadence\n                              </span>\n                              <span className=\"text-sm font-bold text-white block mt-1 font-mono\">{act.avgCadence || \'--\'} <span className=\"text-[9px] font-normal text-gray-500 uppercase\">ppm</span></span>\n                            </div>\n                          </div>\n                        </div>\n\n                        {/* Laps Splits column */}\n                        <div className=\"lg:col-span-2 space-y-3\">\n                          <div className=\"flex items-center justify-between\">\n                            <h5 className=\"text-[9px] font-bold text-gray-400 uppercase tracking-widest flex items-center gap-1\">\n                              <Layers className=\"h-3.5 w-3.5 text-lime-accent\" />\n                              Lap Splits Sequence\n                            </h5>\n                            <span className=\"text-[9px] font-mono uppercase text-gray-600\">Total {act.laps?.length || 0} index cycles</span>\n                          </div>\n\n                          <div className=\"overflow-hidden border border-white/5 bg-[#0F1115]/50 rounded\">\n                            <table className=\"w-full text-left border-collapse text-xs\">\n                              <thead>\n                                <tr className=\"border-b border-white/10 text-[8px] text-gray-500 uppercase tracking-widest font-bold font-mono bg-[#0F1115]\">\n                                  <th className=\"py-2.5 px-3 text-center w-12\">Lp</th>\n                                  <th className=\"py-2.5 px-3\">Distance</th>\n                                  <th className=\"py-2.5 px-3\">Time</th>\n                                  <th className=\"py-2.5 px-3\">Pace</th>\n                                  <th className=\"py-2.5 px-3\">Mean HR</th>\n                                  <th className=\"py-2.5 px-3\">Cadence</th>\n                                </tr>\n                              </thead>\n                              <tbody className=\"font-mono\">\n                                {act.laps && act.laps.map((lap) => {\n                                  // calculate pace for the lap\n                                  const paceSeconds = lap.distanceKm > 0 ? (lap.durationSec / lap.distanceKm) : 0;\n                                  let lapPaceStr = \'--:--\';\n                                  if (paceSeconds > 0) {\n                                    const min = Math.floor(paceSeconds / 60);\n                                    const sec = Math.round(paceSeconds % 60);\n                                    lapPaceStr = `${min.toString().padStart(2, \'0\')}:${sec.toString().padStart(2, \'0\')}`;\n                                  }\n\n                                  return (\n                                    <tr key={lap.lapIndex} className=\"border-b border-white/5 hover:bg-white/5 last:border-0 transition-colors\">\n                                      <td className=\"py-2 px-3 text-center font-bold text-gray-500 bg-black/20\">{lap.lapIndex}</td>\n                                      <td className=\"py-2 px-3 font-bold text-white\">{lap.distanceKm.toFixed(2)} KM</td>\n                                      <td className=\"py-2 px-3 text-slate-300\">{formatDuration(lap.durationSec)}</td>\n                                      <td className=\"py-2 px-3 text-cyan-400 font-bold\">{lapPaceStr}/KM</td>\n                                      <td className=\"py-2 px-3 text-rose-500 font-bold\">{lap.avgHeartRate ? `${lap.avgHeartRate}` : \'--\'}</td>\n                                      <td className=\"py-2 px-3 text-slate-400\">{lap.avgCadence ? `${lap.avgCadence}` : \'--\'}</td>\n                                    </tr>\n                                  );\n                                })}\n\n                                {(!act.laps || act.laps.length === 0) && (\n                                  <tr>\n                                    <td colSpan={6} className=\"py-8 text-center text-gray-650 uppercase text-[10px] font-mono italic\">\n                                      No detailed split intervals compiled.\n                                    </td>\n                                  </tr>\n                                )}\n                              </tbody>\n                            </table>\n                          </div>\n                        </div>\n\n                      </div>\n                    </motion.div>\n                  )}\n                </AnimatePresence>\n              </div>\n            );\n          })}\n\n          {activities.length === 0 && (\n            <div className=\"text-center py-12 bg-[#0F1115] border border-white/10 rounded text-gray-500 text-xs font-mono uppercase\">\n              No sessions found. Sync a .tcx telemetry log sequence to initialize index databases.\n            </div>\n          )}\n        </div>\n      </div>\n\n    </div>"
      }
      num_matches: 1
    }
  }
}
