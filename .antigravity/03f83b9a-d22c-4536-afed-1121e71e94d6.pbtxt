  file_change {
    absolute_path_uri: "file:///src/components/History.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React, { useState, useRef } from \'react\';\nimport { motion, AnimatePresence } from \'motion/react\';\nimport {\n  UploadCloud,\n  ChevronDown,\n  ChevronUp,\n  MapPin,\n  Clock,\n  Heart,\n  Flame,\n  Activity,\n  Smartphone,\n  Calendar,\n  Layers,\n  AlertCircle,\n  FileCheck\n} from \'lucide-react\';\nimport { Activity as ActivityType } from \'../types.js\';\n\ninterface HistoryProps {\n  activities: ActivityType[];\n  onUploadTcx: (file: File) => Promise<void>;\n  isUploading: boolean;\n  uploadError: string | null;\n  uploadSuccess: string | null;\n}\n\nexport default function History({ activities, onUploadTcx, isUploading, uploadError, uploadSuccess }: HistoryProps) {\n  const [expandedActivityId, setExpandedActivityId] = useState<string | null>(null);\n  const [dragActive, setDragActive] = useState(false);\n  const fileInputRef = useRef<HTMLInputElement>(null);\n\n  // Toggle expanded card\n  const toggleExpand = (id: string) => {\n    setExpandedActivityId(prev => (prev === id ? null : id));\n  };\n\n  // Convert seconds to MM:SS format\n  const formatDuration = (totalSeconds: number) => {\n    const minutes = Math.floor(totalSeconds / 60);\n    const seconds = totalSeconds % 60;\n    return `${minutes.toString().padStart(2, \'0\')}:${seconds.toString().padStart(2, \'0\')}`;\n  };\n\n  // Drag and Drop handlers\n  const handleDrag = (e: React.DragEvent) => {\n    e.preventDefault();\n    e.stopPropagation();\n    if (e.type === \'dragenter\' || e.type === \'dragover\') {\n      setDragActive(true);\n    } else if (e.type === \'dragleave\') {\n      setDragActive(false);\n    }\n  };\n\n  const handleDrop = async (e: React.DragEvent) => {\n    e.preventDefault();\n    e.stopPropagation();\n    setDragActive(false);\n\n    if (e.dataTransfer.files && e.dataTransfer.files[0]) {\n      const file = e.dataTransfer.files[0];\n      if (file.name.endsWith(\'.tcx\')) {\n        await onUploadTcx(file);\n      } else {\n        alert(\'Carica solo file .tcx di Garmin o Strava\');\n      }\n    }\n  };\n\n  const handleFileChange = async (e: React.ChangeEvent<HTMLInputElement>) => {\n    e.preventDefault();\n    if (e.target.files && e.target.files[0]) {\n      const file = e.target.files[0];\n      await onUploadTcx(file);\n    }\n  };\n\n  const triggerFileInput = () => {\n    fileInputRef.current?.click();\n  };\n\n  return (\n    <div className=\"space-y-8\" id=\"history-tab\">\n      \n      {/* Page Title */}\n      <div>\n        <h2 className=\"text-2xl font-bold tracking-tight text-white flex items-center gap-2\">\n          <Calendar className=\"h-6 w-6 text-emerald-400\" />\n          Storico Allenamenti\n        </h2>\n        <p className=\"text-slate-400 text-sm mt-1\">\n          Carica file TCX per sincronizzare le corse o consulta lo storico completo dei tuoi giri e tempi.\n        </p>\n      </div>\n\n      {/* Upload Zone */}\n      <div \n        onDragEnter={handleDrag}\n        onDragOver={handleDrag}\n        onDragLeave={handleDrag}\n        onDrop={handleDrop}\n        className={`border-2 border-dashed rounded-2xl p-8 text-center transition-all duration-200 relative overflow-hidden flex flex-col items-center justify-center cursor-pointer ${\n          dragActive \n            ? \'border-emerald-500 bg-emerald-500/5\' \n            : \'border-slate-800 bg-slate-900/20 hover:border-slate-700/80 hover:bg-slate-900/30\'\n        }`}\n        onClick={triggerFileInput}\n        id=\"tcx-upload-zone\"\n      >\n        <input \n          ref={fileInputRef}\n          type=\"file\"\n          accept=\".tcx\"\n          onChange={handleFileChange}\n          className=\"hidden\"\n        />\n\n        <div className=\"space-y-4 max-w-sm\">\n          {/* Icons container */}\n          <div className=\"mx-auto h-12 w-12 rounded-2xl bg-emerald-500/10 text-emerald-400 flex items-center justify-center shadow-lg\">\n            {isUploading ? (\n              <svg className=\"animate-spin h-5 w-5 text-emerald-400\" fill=\"none\" viewBox=\"0 0 24 24\">\n                <circle className=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" strokeWidth=\"4\"></circle>\n                <path className=\"opacity-75\" fill=\"currentColor\" d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\"></path>\n              </svg>\n            ) : (\n              <UploadCloud className=\"h-6 w-6\" />\n            )}\n          </div>\n\n          <div className=\"space-y-1\">\n            <p className=\"text-sm font-semibold text-white\">\n              {isUploading ? \'Analisi del file in corso...\' : \'Trascina qui il tuo file .tcx\'}\n            </p>\n            <p className=\"text-xs text-slate-400 leading-relaxed\">\n              oppure <span className=\"text-emerald-400 font-bold underline hover:text-emerald-300\">clicca per sfogliare</span> il computer (file TCX Garmin/Strava)\n            </p>\n          </div>\n        </div>\n\n        {/* Error / Success Banners */}\n        <AnimatePresence>\n          {uploadError && (\n            <motion.div \n              initial={{ opacity: 0, y: 10 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, y: 10 }}\n              className=\"absolute bottom-3 left-4 right-4 bg-rose-500/10 border border-rose-500/20 rounded-xl px-4 py-2.5 flex items-center gap-2.5 text-xs text-rose-400 text-left\"\n            >\n              <AlertCircle className=\"h-4 w-4 shrink-0\" />\n              <span>{uploadError}</span>\n            </motion.div>\n          )}\n\n          {uploadSuccess && (\n            <motion.div \n              initial={{ opacity: 0, y: 10 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, y: 10 }}\n              className=\"absolute bottom-3 left-4 right-4 bg-emerald-500/10 border border-emerald-500/20 rounded-xl px-4 py-2.5 flex items-center gap-2.5 text-xs text-emerald-400 text-left\"\n            >\n              <FileCheck className=\"h-4 w-4 shrink-0\" />\n              <span>{uploadSuccess}</span>\n            </motion.div>\n          )}\n        </AnimatePresence>\n      </div>\n\n      {/* History List */}\n      <div className=\"space-y-4\">\n        <div className=\"flex items-center justify-between\">\n          <h3 className=\"text-sm font-semibold text-slate-400\">Tutte le Sessioni ({activities.length})</h3>\n          <span className=\"text-[10px] text-slate-500\">Clicca su un allenamento per i dettagli dei giri (splits)</span>\n        </div>\n\n        <div className=\"space-y-3\" id=\"activities-history-list\">\n          {activities.map((act) => {\n            const isExpanded = expandedActivityId === act.id;\n            const dateStr = new Date(act.date).toLocaleDateString(\'it-IT\', {\n              weekday: \'short\',\n              day: \'numeric\',\n              month: \'long\',\n              year: \'numeric\'\n            });\n            const timeStr = new Date(act.date).toLocaleTimeString(\'it-IT\', {\n              hour: \'2-digit\',\n              minute: \'2-digit\'\n            });\n\n            return (\n              <div \n                key={act.id}\n                className={`bg-slate-900 border rounded-2xl overflow-hidden transition-all duration-200 ${\n                  isExpanded ? \'border-emerald-500/40 shadow-xl\' : \'border-slate-800 hover:border-slate-700/80\'\n                }`}\n              >\n                {/* Main Header Item */}\n                <div \n                  onClick={() => toggleExpand(act.id)}\n                  className=\"p-4 md:p-5 flex items-center justify-between gap-4 cursor-pointer select-none\"\n                >\n                  <div className=\"flex items-center gap-4 min-w-0\">\n                    {/* Badge Distance */}\n                    <div className=\"h-12 w-12 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 flex flex-col items-center justify-center shrink-0\">\n                      <span className=\"text-sm font-bold tracking-tight font-mono\">{act.distanceKm.toFixed(1)}</span>\n                      <span className=\"text-[8px] font-medium uppercase tracking-wider -mt-1\">km</span>\n                    </div>\n\n                    <div className=\"min-w-0\">\n                      <h4 className=\"text-sm font-bold text-white group-hover:text-emerald-400 transition-colors truncate\">\n                        {act.name}\n                      </h4>\n                      <p className=\"text-[10px] text-slate-500 flex items-center gap-1.5 mt-1 font-medium\">\n                        <span>{dateStr}</span>\n                        <span>\342\200\242</span>\n                        <span>{timeStr}</span>\n                        {act.deviceModel && (\n                          <>\n                            <span>\342\200\242</span>\n                            <span className=\"flex items-center gap-0.5\">\n                              <Smartphone className=\"h-3 w-3\" />\n                              {act.deviceModel}\n                            </span>\n                          </>\n                        )}\n                      </p>\n                    </div>\n                  </div>\n\n                  {/* Quick Stats Grid */}\n                  <div className=\"flex items-center gap-6\">\n                    <div className=\"hidden sm:grid grid-cols-3 gap-6 text-right\">\n                      <div>\n                        <span className=\"text-[10px] text-slate-500 uppercase font-bold tracking-wider block\">Passo</span>\n                        <span className=\"text-xs font-semibold text-white font-mono mt-0.5 block\">{act.avgPace}</span>\n                      </div>\n                      <div>\n                        <span className=\"text-[10px] text-slate-500 uppercase font-bold tracking-wider block\">Durata</span>\n                        <span className=\"text-xs font-semibold text-white font-mono mt-0.5 block\">{act.durationMin} min</span>\n                      </div>\n                      <div>\n                        <span className=\"text-[10px] text-slate-500 uppercase font-bold tracking-wider block\">Zone HR</span>\n                        <span className=\"text-xs font-semibold text-rose-400 font-mono mt-0.5 block\">\n                          {act.avgHeartRate ? `${act.avgHeartRate} bpm` : \'--\'}\n                        </span>\n                      </div>\n                    </div>\n\n                    {/* Expand Chevron */}\n                    <div className=\"text-slate-400 p-1.5 hover:bg-slate-800 rounded-lg transition-colors\">\n                      {isExpanded ? <ChevronUp className=\"h-4.5 w-4.5\" /> : <ChevronDown className=\"h-4.5 w-4.5\" />}\n                    </div>\n                  </div>\n                </div>\n\n                {/* Expanded Details Drawer */}\n                <AnimatePresence>\n                  {isExpanded && (\n                    <motion.div\n                      initial={{ height: 0, opacity: 0 }}\n                      animate={{ height: \'auto\', opacity: 1 }}\n                      exit={{ height: 0, opacity: 0 }}\n                      transition={{ duration: 0.25 }}\n                      className=\"border-t border-slate-800 bg-slate-950/40\"\n                    >\n                      <div className=\"p-5 grid grid-cols-1 lg:grid-cols-3 gap-6\">\n                        \n                        {/* Summary & Note columns */}\n                        <div className=\"space-y-4\">\n                          <h5 className=\"text-xs font-bold text-slate-400 uppercase tracking-wider\">Note & Dispositivo</h5>\n                          \n                          <div className=\"bg-slate-900 border border-slate-800/80 rounded-xl p-3.5 space-y-3 text-xs\">\n                            {act.notes ? (\n                              <p className=\"text-slate-300 italic leading-relaxed\">{act.notes}</p>\n                            ) : (\n                              <p className=\"text-slate-500\">Nessuna nota inserita per questa attivit\303\240.</p>\n                            )}\n\n                            <div className=\"pt-2 border-t border-slate-800 flex items-center justify-between text-[11px] text-slate-400\">\n                              <span className=\"flex items-center gap-1\">\n                                <Smartphone className=\"h-3.5 w-3.5 text-emerald-400\" />\n                                {act.deviceBrand || \'Garmin\'} {act.deviceModel}\n                              </span>\n                              <span className=\"capitalize font-medium text-emerald-400\">{act.sport || \'Corsa\'}</span>\n                            </div>\n                          </div>\n\n                          {/* Secondary Metrics */}\n                          <div className=\"grid grid-cols-2 gap-3\">\n                            <div className=\"bg-slate-900 border border-slate-800/50 p-3 rounded-xl\">\n                              <span className=\"text-[10px] text-slate-500 flex items-center gap-1 font-bold uppercase tracking-wider\">\n                                <Flame className=\"h-3.5 w-3.5 text-amber-500\" />\n                                Calorie\n                              </span>\n                              <span className=\"text-sm font-bold text-white block mt-1 font-mono\">{act.calories} <span className=\"text-[10px] font-normal text-slate-400\">kcal</span></span>\n                            </div>\n                            <div className=\"bg-slate-900 border border-slate-800/50 p-3 rounded-xl\">\n                              <span className=\"text-[10px] text-slate-500 flex items-center gap-1 font-bold uppercase tracking-wider\">\n                                <Activity className=\"h-3.5 w-3.5 text-cyan-400\" />\n                                Cadenza Media\n                              </span>\n                              <span className=\"text-sm font-bold text-white block mt-1 font-mono\">{act.avgCadence || \'--\'} <span className=\"text-[10px] font-normal text-slate-400\">ppm</span></span>\n                            </div>\n                          </div>\n                        </div>\n\n                        {/* Laps Splits column (2/3 width on desktop) */}\n                        <div className=\"lg:col-span-2 space-y-4\">\n                          <div className=\"flex items-center justify-between\">\n                            <h5 className=\"text-xs font-bold text-slate-400 uppercase tracking-wider flex items-center gap-1\">\n                              <Layers className=\"h-3.5 w-3.5 text-emerald-400\" />\n                              Dettagli Giri (Splits)\n                            </h5>\n                            <span className=\"text-[9px] text-slate-500\">Totale {act.laps?.length || 0} giri</span>\n                          </div>\n\n                          <div className=\"overflow-x-auto border border-slate-850 bg-slate-900/40 rounded-xl\">\n                            <table className=\"w-full text-left border-collapse text-xs\">\n                              <thead>\n                                <tr className=\"border-b border-slate-800 text-[10px] text-slate-500 uppercase tracking-wider font-bold bg-slate-900/60\">\n                                  <th className=\"py-2.5 px-4 text-center w-12\">Giro</th>\n                                  <th className=\"py-2.5 px-4\">Distanza</th>\n                                  <th className=\"py-2.5 px-4\">Tempo</th>\n                                  <th className=\"py-2.5 px-4\">Passo</th>\n                                  <th className=\"py-2.5 px-4\">FC Media</th>\n                                  <th className=\"py-2.5 px-4\">Cadenza</th>\n                                </tr>\n                              </thead>\n                              <tbody>\n                                {act.laps && act.laps.map((lap) => {\n                                  // calculate pace for the lap\n                                  const lapMin = lap.durationSec / 60;\n                                  const paceSeconds = lap.distanceKm > 0 ? (lap.durationSec / lap.distanceKm) : 0;\n                                  let lapPaceStr = \'--:--\';\n                                  if (paceSeconds > 0) {\n                                    const min = Math.floor(paceSeconds / 60);\n                                    const sec = Math.round(paceSeconds % 60);\n                                    lapPaceStr = `${min.toString().padStart(2, \'0\')}:${sec.toString().padStart(2, \'0\')}`;\n                                  }\n\n                                  return (\n                                    <tr key={lap.lapIndex} className=\"border-b border-slate-850 hover:bg-slate-900/20 last:border-0 transition-colors\">\n                                      <td className=\"py-2 px-4 text-center font-bold text-slate-400 font-mono bg-slate-900/20\">{lap.lapIndex}</td>\n                                      <td className=\"py-2 px-4 font-semibold text-white font-mono\">{lap.distanceKm.toFixed(2)} km</td>\n                                      <td className=\"py-2 px-4 text-slate-300 font-mono\">{formatDuration(lap.durationSec)}</td>\n                                      <td className=\"py-2 px-4 text-cyan-400 font-bold font-mono\">{lapPaceStr}/km</td>\n                                      <td className=\"py-2 px-4 text-rose-400 font-mono\">{lap.avgHeartRate ? `${lap.avgHeartRate} bpm` : \'--\'}</td>\n                                      <td className=\"py-2 px-4 text-slate-300 font-mono\">{lap.avgCadence ? `${lap.avgCadence} ppm` : \'--\'}</td>\n                                    </tr>\n                                  );\n                                })}\n\n                                {(!act.laps || act.laps.length === 0) && (\n                                  <tr>\n                                    <td colSpan={6} className=\"py-8 text-center text-slate-500 italic\">\n                                      Nessun dettaglio giro registrato nel file.\n                                    </td>\n                                  </tr>\n                                )}\n                              </tbody>\n                            </table>\n                          </div>\n                        </div>\n\n                      </div>\n                    </motion.div>\n                  )}\n                </AnimatePresence>\n              </div>\n            );\n          })}\n\n          {activities.length === 0 && (\n            <div className=\"text-center py-12 bg-slate-900/30 border border-slate-800 rounded-2xl text-slate-400 text-sm\">\n              Non \303\250 ancora presente alcun allenamento registrato. Sincronizza il tuo primo file TCX per iniziare!\n            </div>\n          )}\n        </div>\n      </div>\n\n    </div>\n  );\n}\n"
    }
