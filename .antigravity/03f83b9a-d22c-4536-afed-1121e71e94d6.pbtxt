    instruction: "Apply High Density styling (colors, borders, bubbles, lime accents, custom text fields) to Chat component"
    replacement_infos {
      original_chunk {
        target_content: "  return (\n    <div className=\"flex flex-col h-[calc(100vh-12rem)] min-h-[480px] bg-slate-900/40 border border-slate-800/80 rounded-2xl overflow-hidden shadow-xl\" id=\"chat-tab\">\n      \n      {/* Chat Header */}\n      <div className=\"bg-slate-900 border-b border-slate-800 px-5 py-3.5 flex items-center justify-between\">\n        <div className=\"flex items-center gap-3\">\n          <div className=\"h-10 w-10 rounded-xl bg-gradient-to-tr from-emerald-500 to-teal-500 text-white flex items-center justify-center shadow-lg shadow-emerald-500/10\">\n            <Sparkles className=\"h-5 w-5\" />\n          </div>\n          <div>\n            <h3 className=\"text-sm font-bold text-white flex items-center gap-2\">\n              Running Coach AI\n              <span className=\"h-2 w-2 rounded-full bg-emerald-400 animate-pulse\"></span>\n            </h3>\n            <p className=\"text-[10px] text-slate-400\">Pronto a ottimizzare la tua corsa</p>\n          </div>\n        </div>\n\n        <div className=\"flex items-center gap-2\">\n          {/* Clear History Button */}\n          <button\n            onClick={() => setShowClearConfirm(true)}\n            className=\"p-2 text-slate-400 hover:text-rose-400 hover:bg-rose-500/10 rounded-xl transition-all duration-200\"\n            title=\"Svuota cronologia chat\"\n          >\n            <Trash2 className=\"h-4.5 w-4.5\" />\n          </button>\n        </div>\n      </div>\n\n      {/* Model Selection Banner */}\n      <div className=\"bg-slate-950 px-4 py-2 border-b border-slate-800/60 flex flex-wrap items-center justify-between gap-2\">\n        <div className=\"flex items-center gap-1.5\">\n          <Cpu className=\"h-3.5 w-3.5 text-slate-500\" />\n          <span className=\"text-[10px] text-slate-400 font-medium\">Motore LLM:</span>\n        </div>\n        <div className=\"flex bg-slate-900 p-0.5 rounded-lg border border-slate-800 text-[10px] font-semibold\">\n          <button\n            onClick={() => setModelMode(\'auto\')}\n            className={`px-2.5 py-1 rounded-md transition-all duration-200 ${modelMode === \'auto\' ? \'bg-emerald-500 text-slate-950 font-bold\' : \'text-slate-400 hover:text-white\'}`}\n          >\n            Rilevamento Auto\n          </button>\n          <button\n            onClick={() => setModelMode(\'groq\')}\n            className={`px-2.5 py-1 rounded-md transition-all duration-200 flex items-center gap-1 ${modelMode === \'groq\' ? \'bg-amber-500 text-slate-950 font-bold\' : \'text-slate-400 hover:text-white\'}`}\n          >\n            <Zap className=\"h-3 w-3\" />\n            Groq Veloce\n          </button>\n          <button\n            onClick={() => setModelMode(\'premium\')}\n            className={`px-2.5 py-1 rounded-md transition-all duration-200 flex items-center gap-1 ${modelMode === \'premium\' ? \'bg-cyan-500 text-slate-950 font-bold\' : \'text-slate-400 hover:text-white\'}`}\n          >\n            <Trophy className=\"h-3 w-3\" />\n            Premium Piano\n          </button>\n        </div>\n      </div>\n\n      {/* Messages Scrolling View */}\n      <div className=\"flex-1 overflow-y-auto p-5 space-y-6 scrollbar-thin scrollbar-thumb-slate-800\" id=\"chat-messages-container\">\n        {chatHistory.map((msg) => (\n          <div\n            key={msg.id}\n            className={`flex gap-4 ${msg.sender === \'user\' ? \'justify-end\' : \'justify-start\'}`}\n          >\n            {/* Assistant Avatar */}\n            {msg.sender === \'assistant\' && (\n              <div className=\"h-9 w-9 rounded-xl bg-slate-800 border border-slate-700/60 flex items-center justify-center text-emerald-400 shrink-0 shadow-md\">\n                <Activity className=\"h-4.5 w-4.5\" />\n              </div>\n            )}\n\n            <div className={`flex flex-col max-w-[85%] md:max-w-[75%] ${msg.sender === \'user\' ? \'items-end\' : \'items-start\'}`}>\n              \n              {/* Message Metadata (Model Badge, etc) */}\n              <div className=\"flex items-center gap-2 mb-1\">\n                <span className=\"text-[9px] text-slate-500\">\n                  {new Date(msg.timestamp).toLocaleTimeString(\'it-IT\', { hour: \'2-digit\', minute: \'2-digit\' })}\n                </span>\n                {msg.sender === \'assistant\' && msg.modelUsed && (\n                  <span className={`text-[8px] px-1.5 py-0.5 rounded-full border font-mono font-bold ${\n                    msg.isPlan \n                      ? \'bg-cyan-500/5 text-cyan-400 border-cyan-500/20\' \n                      : \'bg-amber-500/5 text-amber-400 border-amber-500/20\'\n                  }`}>\n                    {msg.modelUsed}\n                  </span>\n                )}\n              </div>\n\n              {/* Message Bubble */}\n              <div className={`p-4 rounded-2xl leading-relaxed text-sm shadow-md border ${\n                msg.sender === \'user\'\n                  ? \'bg-emerald-600 text-white rounded-tr-none border-emerald-500\'\n                  : \'bg-slate-900 text-slate-100 rounded-tl-none border-slate-800/80\'\n              }`}>\n                {msg.sender === \'user\' ? (\n                  <p className=\"whitespace-pre-wrap\">{msg.text}</p>\n                ) : (\n                  <div className=\"markdown-body prose prose-invert max-w-none text-slate-200\">\n                    <Markdown>{msg.text}</Markdown>\n                  </div>\n                )}\n              </div>\n\n              {/* Saved Plan Indicator */}\n              {msg.sender === \'assistant\' && msg.isPlan && (\n                <div className=\"mt-2 text-[10px] text-emerald-400 flex items-center gap-1 font-semibold px-1\">\n                  <span className=\"h-1.5 w-1.5 bg-emerald-400 rounded-full animate-ping\"></span>\n                  Piano settimanale salvato in archivio\n                </div>\n              )}\n            </div>\n\n            {/* User Avatar */}\n            {msg.sender === \'user\' && (\n              <div className=\"h-9 w-9 rounded-xl bg-emerald-600/20 border border-emerald-500/30 flex items-center justify-center text-emerald-400 shrink-0 shadow-md\">\n                <span className=\"text-xs font-bold font-mono\">TU</span>\n              </div>\n            )}\n          </div>\n        ))}\n\n        {/* Sending Indicator */}\n        {isSending && (\n          <div className=\"flex gap-4 justify-start\">\n            <div className=\"h-9 w-9 rounded-xl bg-slate-800 border border-slate-700/60 flex items-center justify-center text-emerald-400 shrink-0 animate-pulse\">\n              <Activity className=\"h-4.5 w-4.5\" />\n            </div>\n            <div className=\"flex flex-col items-start max-w-[75%]\">\n              <div className=\"text-[9px] text-slate-500 mb-1 flex items-center gap-1\">\n                <RefreshCw className=\"h-2.5 w-2.5 animate-spin\" />\n                {getTargetModelName()} sta elaborando...\n              </div>\n              <div className=\"p-4 bg-slate-900 text-slate-300 rounded-2xl rounded-tl-none border border-slate-800/80 shadow-md flex items-center gap-3\">\n                <div className=\"flex space-x-1.5\">\n                  <div className=\"h-2.5 w-2.5 bg-emerald-400 rounded-full animate-bounce\" style={{ animationDelay: \'0ms\' }}></div>\n                  <div className=\"h-2.5 w-2.5 bg-emerald-400 rounded-full animate-bounce\" style={{ animationDelay: \'150ms\' }}></div>\n                  <div className=\"h-2.5 w-2.5 bg-emerald-400 rounded-full animate-bounce\" style={{ animationDelay: \'300ms\' }}></div>\n                </div>\n                <span className=\"text-xs text-slate-400\">Analisi parametri in corso...</span>\n              </div>\n            </div>\n          </div>\n        )}\n\n        <div ref={messagesEndRef} />\n      </div>\n\n      {/* Real-time Keyword Notification Banner */}\n      {input.trim() && (\n        <div className=\"bg-slate-950/80 px-5 py-1.5 border-t border-slate-800/60 text-[10px] text-slate-400 flex items-center justify-between\">\n          <div className=\"flex items-center gap-1\">\n            <Info className=\"h-3 w-3 text-emerald-400\" />\n            <span>Andr\303\240 a: <strong className=\"text-slate-200\">{getTargetModelName()}</strong></span>\n          </div>\n          {isPlanDetected() && (\n            <span className=\"text-emerald-400 font-bold bg-emerald-400/5 border border-emerald-500/20 px-1.5 py-0.5 rounded\">\n              \342\232\241 Trigger Piano Settimanale Rilevato\n            </span>\n          )}\n        </div>\n      )}\n\n      {/* Input Form Bar */}\n      <form onSubmit={handleSend} className=\"bg-slate-900 border-t border-slate-800 p-4 flex gap-3\">\n        <input\n          type=\"text\"\n          value={input}\n          onChange={(e) => setInput(e.target.value)}\n          disabled={isSending}\n          placeholder={\n            modelMode === \'premium\' \n              ? \"Chiedi una tabella: es. \'Crea un piano di 4 settimane per i 10km\'...\" \n              : \"Fai una domanda veloce sul tuo allenamento o chiedi un piano...\"\n          }\n          className=\"flex-1 bg-slate-950 border border-slate-800 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500/30 rounded-xl px-4 py-3 text-sm text-white placeholder-slate-500 outline-none transition-all\"\n          id=\"chat-input-field\"\n        />\n        <button\n          type=\"submit\"\n          disabled={!input.trim() || isSending}\n          className=\"bg-emerald-500 hover:bg-emerald-400 disabled:bg-slate-800 text-slate-950 disabled:text-slate-600 rounded-xl px-4 flex items-center justify-center font-bold transition-colors shadow-lg shadow-emerald-500/10 cursor-pointer\"\n          id=\"chat-submit-btn\"\n        >\n          <Send className=\"h-4.5 w-4.5\" />\n        </button>\n      </form>\n\n      {/* Clear Chat Confirmation Modal */}\n      <AnimatePresence>\n        {showClearConfirm && (\n          <motion.div\n            initial={{ opacity: 0 }}\n            animate={{ opacity: 1 }}\n            exit={{ opacity: 0 }}\n            className=\"absolute inset-0 bg-slate-950/80 backdrop-blur-sm flex items-center justify-center p-4 z-50\"\n          >\n            <motion.div\n              initial={{ scale: 0.95, opacity: 0 }}\n              animate={{ scale: 1, opacity: 1 }}\n              exit={{ scale: 0.95, opacity: 0 }}\n              className=\"bg-slate-900 border border-slate-800 p-6 rounded-2xl max-w-sm w-full shadow-2xl text-center space-y-4\"\n            >\n              <div className=\"h-12 w-12 rounded-xl bg-rose-500/10 text-rose-400 flex items-center justify-center mx-auto\">\n                <Trash2 className=\"h-6 w-6\" />\n              </div>\n              <div className=\"space-y-1.5\">\n                <h4 className=\"text-md font-bold text-white\">Svuotare la chat?</h4>\n                <p className=\"text-xs text-slate-400 leading-relaxed\">\n                  L\'intera cronologia di messaggi con il Running Coach AI verr\303\240 cancellata irreversibilmente.\n                </p>\n              </div>\n              <div className=\"flex gap-3 pt-2\">\n                <button\n                  onClick={() => setShowClearConfirm(false)}\n                  className=\"flex-1 bg-slate-800 border border-slate-700 hover:bg-slate-700 text-slate-300 text-xs font-semibold py-2 rounded-xl transition-colors\"\n                >\n                  Annulla\n                </button>\n                <button\n                  onClick={async () => {\n                    await onClearHistory();\n                    setShowClearConfirm(false);\n                  }}\n                  className=\"flex-1 bg-rose-600 hover:bg-rose-500 text-white text-xs font-semibold py-2 rounded-xl transition-colors\"\n                >\n                  S\303\254, cancella\n                </button>\n              </div>\n            </motion.div>\n          </motion.div>\n        )}\n      </AnimatePresence>\n\n    </div>"
        replacement_content: "  return (\n    <div className=\"flex flex-col h-[calc(100vh-12rem)] min-h-[480px] bg-highdensity-bg border border-white/10 rounded overflow-hidden shadow-2xl\" id=\"chat-tab\">\n      \n      {/* High Density Chat Header */}\n      <div className=\"bg-[#0F1115] border-b border-white/10 px-5 py-3 flex items-center justify-between\">\n        <div className=\"flex items-center gap-3\">\n          <div className=\"h-8 w-8 bg-lime-accent rounded-sm flex items-center justify-center text-black shadow-lg\">\n            <Sparkles className=\"h-4 w-4\" />\n          </div>\n          <div>\n            <h3 className=\"text-xs font-bold uppercase tracking-wider text-white flex items-center gap-2\">\n              Coach Terminal\n              <span className=\"h-1.5 w-1.5 rounded-full bg-lime-accent animate-pulse\"></span>\n            </h3>\n            <p className=\"text-[9px] text-gray-500 font-mono uppercase tracking-wide\">Ready for prompt execution</p>\n          </div>\n        </div>\n\n        <div className=\"flex items-center gap-2\">\n          {/* Clear History Button */}\n          <button\n            onClick={() => setShowClearConfirm(true)}\n            className=\"p-1.5 text-gray-500 hover:text-rose-400 hover:bg-rose-500/10 rounded transition-all\"\n            title=\"Svuota cronologia chat\"\n          >\n            <Trash2 className=\"h-4 w-4\" />\n          </button>\n        </div>\n      </div>\n\n      {/* Model Selection Banner */}\n      <div className=\"bg-[#0B0C0E] px-4 py-2 border-b border-white/5 flex flex-wrap items-center justify-between gap-2\">\n        <div className=\"flex items-center gap-1.5 font-mono\">\n          <Cpu className=\"h-3.5 w-3.5 text-gray-500\" />\n          <span className=\"text-[9px] text-gray-400 uppercase font-bold tracking-wider\">Engine core:</span>\n        </div>\n        <div className=\"flex bg-[#0F1115] p-0.5 rounded border border-white/5 text-[9px] font-mono uppercase font-bold\">\n          <button\n            onClick={() => setModelMode(\'auto\')}\n            className={`px-2.5 py-0.5 rounded-sm transition-all ${modelMode === \'auto\' ? \'bg-lime-accent text-black font-extrabold\' : \'text-gray-400 hover:text-white\'}`}\n          >\n            Auto Detect\n          </button>\n          <button\n            onClick={() => setModelMode(\'groq\')}\n            className={`px-2.5 py-0.5 rounded-sm transition-all flex items-center gap-1 ${modelMode === \'groq\' ? \'bg-amber-500 text-black font-extrabold\' : \'text-gray-400 hover:text-white\'}`}\n          >\n            <Zap className=\"h-2.5 w-2.5\" />\n            Groq Llama\n          </button>\n          <button\n            onClick={() => setModelMode(\'premium\')}\n            className={`px-2.5 py-0.5 rounded-sm transition-all flex items-center gap-1 ${modelMode === \'premium\' ? \'bg-cyan-450 bg-cyan-400 text-black font-extrabold\' : \'text-gray-400 hover:text-white\'}`}\n          >\n            <Trophy className=\"h-2.5 w-2.5\" />\n            Premium AI\n          </button>\n        </div>\n      </div>\n\n      {/* Messages Scrolling View */}\n      <div className=\"flex-1 overflow-y-auto p-5 space-y-5 bg-[#0B0C0E]\" id=\"chat-messages-container\">\n        {chatHistory.map((msg) => (\n          <div\n            key={msg.id}\n            className={`flex gap-3.5 ${msg.sender === \'user\' ? \'justify-end\' : \'justify-start\'}`}\n          >\n            {/* Assistant Avatar */}\n            {msg.sender === \'assistant\' && (\n              <div className=\"h-8 w-8 rounded-sm bg-white/5 border border-white/10 flex items-center justify-center text-lime-accent shrink-0\">\n                <Activity className=\"h-4 w-4\" />\n              </div>\n            )}\n\n            <div className={`flex flex-col max-w-[85%] md:max-w-[75%] ${msg.sender === \'user\' ? \'items-end\' : \'items-start\'}`}>\n              \n              {/* Message Metadata */}\n              <div className=\"flex items-center gap-2 mb-1.5 font-mono\">\n                <span className=\"text-[8px] text-gray-500 uppercase font-bold tracking-wider\">\n                  {new Date(msg.timestamp).toLocaleTimeString(\'it-IT\', { hour: \'2-digit\', minute: \'2-digit\' })}\n                </span>\n                {msg.sender === \'assistant\' && msg.modelUsed && (\n                  <span className={`text-[8px] px-1.5 py-0.2 rounded-sm border font-mono font-bold uppercase ${\n                    msg.isPlan \n                      ? \'bg-cyan-500/5 text-cyan-400 border-cyan-500/20\' \n                      : \'bg-amber-500/5 text-amber-400 border-amber-500/20\'\n                  }`}>\n                    {msg.modelUsed}\n                  </span>\n                )}\n              </div>\n\n              {/* High Density Message Bubbles */}\n              <div className={`p-3 text-sm font-sans border shadow-md ${\n                msg.sender === \'user\'\n                  ? \'bg-blue-600/10 text-blue-100 rounded-sm border-r-2 border-blue-500 rounded-tr-none\'\n                  : \'bg-white/5 text-slate-200 rounded-sm border-l-2 border-lime-accent rounded-tl-none leading-relaxed\'\n              }`}>\n                {msg.sender === \'user\' ? (\n                  <p className=\"whitespace-pre-wrap\">{msg.text}</p>\n                ) : (\n                  <div className=\"markdown-body prose prose-invert max-w-none text-slate-200\">\n                    <Markdown>{msg.text}</Markdown>\n                  </div>\n                )}\n              </div>\n\n              {/* Saved Plan Indicator */}\n              {msg.sender === \'assistant\' && msg.isPlan && (\n                <div className=\"mt-1.5 text-[9px] text-lime-accent uppercase tracking-wider font-mono font-bold flex items-center gap-1 px-1\">\n                  <span className=\"h-1 w-1 bg-lime-accent rounded-full animate-ping\"></span>\n                  Training Plan Saved To Database\n                </div>\n              )}\n            </div>\n\n            {/* User Avatar */}\n            {msg.sender === \'user\' && (\n              <div className=\"h-8 w-8 rounded-sm bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-blue-400 shrink-0 font-mono text-[10px] font-bold\">\n                USR\n              </div>\n            )}\n          </div>\n        ))}\n\n        {/* Sending Indicator */}\n        {isSending && (\n          <div className=\"flex gap-4 justify-start\">\n            <div className=\"h-8 w-8 rounded-sm bg-white/5 border border-white/10 flex items-center justify-center text-lime-accent shrink-0 animate-pulse\">\n              <Activity className=\"h-4 w-4\" />\n            </div>\n            <div className=\"flex flex-col items-start max-w-[75%]\">\n              <div className=\"text-[8px] font-mono text-gray-500 mb-1 flex items-center gap-1 uppercase tracking-wider\">\n                <RefreshCw className=\"h-2.5 w-2.5 animate-spin\" />\n                {getTargetModelName()} processing...\n              </div>\n              <div className=\"p-3 bg-white/5 text-slate-300 rounded-sm border-l-2 border-lime-accent/50 shadow-md flex items-center gap-3\">\n                <div className=\"flex space-x-1.5\">\n                  <div className=\"h-2 w-2 bg-lime-accent rounded-full animate-bounce\" style={{ animationDelay: \'0ms\' }}></div>\n                  <div className=\"h-2 w-2 bg-lime-accent rounded-full animate-bounce\" style={{ animationDelay: \'150ms\' }}></div>\n                  <div className=\"h-2 w-2 bg-lime-accent rounded-full animate-bounce\" style={{ animationDelay: \'300ms\' }}></div>\n                </div>\n                <span className=\"text-[10px] font-mono text-gray-400 uppercase tracking-wider\">Streaming core tokens...</span>\n              </div>\n            </div>\n          </div>\n        )}\n\n        <div ref={messagesEndRef} />\n      </div>\n\n      {/* Real-time Keyword Notification Banner */}\n      {input.trim() && (\n        <div className=\"bg-[#0B0C0E] px-5 py-1.5 border-t border-white/5 text-[9px] font-mono text-gray-500 flex items-center justify-between uppercase tracking-wider\">\n          <div className=\"flex items-center gap-1.5\">\n            <Info className=\"h-3 w-3 text-lime-accent\" />\n            <span>Core Destination: <strong className=\"text-slate-200\">{getTargetModelName().toUpperCase()}</strong></span>\n          </div>\n          {isPlanDetected() && (\n            <span className=\"text-lime-accent font-extrabold bg-lime-accent/5 border border-lime-accent/20 px-1.5 py-0.5 rounded-sm\">\n              \342\232\241 WEEKLY PLAN KEYWORD DETECTED\n            </span>\n          )}\n        </div>\n      )}\n\n      {/* Input Form Bar */}\n      <form onSubmit={handleSend} className=\"bg-[#0F1115] border-t border-white/10 p-3.5 flex gap-3\">\n        <input\n          type=\"text\"\n          value={input}\n          onChange={(e) => setInput(e.target.value)}\n          disabled={isSending}\n          placeholder={\n            modelMode === \'premium\' \n              ? \"Specify weekly training program formulas: e.g. \'marathon sub-4h\'...\" \n              : \"Ask coaching advice or specify plans (e.g., \'mezza maratona in 4 settimane\')...\"\n          }\n          className=\"flex-1 bg-black/40 border border-white/10 focus:border-lime-accent/50 rounded px-4 py-2.5 text-sm text-white placeholder-gray-600 outline-none transition-all font-sans\"\n          id=\"chat-input-field\"\n        />\n        <button\n          type=\"submit\"\n          disabled={!input.trim() || isSending}\n          className=\"bg-lime-accent hover:bg-lime-accent/90 disabled:bg-white/5 text-black disabled:text-gray-600 rounded-sm px-4 flex items-center justify-center font-extrabold transition-colors cursor-pointer uppercase tracking-wider text-xs\"\n          id=\"chat-submit-btn\"\n        >\n          <Send className=\"h-4 w-4\" />\n        </button>\n      </form>\n\n      {/* Clear Chat Confirmation Modal */}\n      <AnimatePresence>\n        {showClearConfirm && (\n          <motion.div\n            initial={{ opacity: 0 }}\n            animate={{ opacity: 1 }}\n            exit={{ opacity: 0 }}\n            className=\"absolute inset-0 bg-[#0B0C0E]/90 backdrop-blur-sm flex items-center justify-center p-4 z-50\"\n          >\n            <motion.div\n              initial={{ scale: 0.95, opacity: 0 }}\n              animate={{ scale: 1, opacity: 1 }}\n              exit={{ scale: 0.95, opacity: 0 }}\n              className=\"bg-[#0F1115] border border-white/10 p-5 rounded max-w-sm w-full shadow-2xl text-center space-y-4\"\n            >\n              <div className=\"h-10 w-10 rounded bg-rose-500/10 text-rose-400 flex items-center justify-center mx-auto\">\n                <Trash2 className=\"h-5 w-5\" />\n              </div>\n              <div className=\"space-y-1.5\">\n                <h4 className=\"text-xs font-bold uppercase tracking-widest text-white\">Reset Terminal Session?</h4>\n                <p className=\"text-xs text-slate-400 leading-relaxed font-sans\">\n                  The entire coaching chat telemetry history will be cleared. This action is irreversible.\n                </p>\n              </div>\n              <div className=\"flex gap-3 pt-2 font-mono uppercase tracking-wider text-[10px]\">\n                <button\n                  onClick={() => setShowClearConfirm(false)}\n                  className=\"flex-1 bg-black/40 border border-white/10 hover:bg-white/5 text-slate-300 font-bold py-2 rounded transition-colors\"\n                >\n                  Cancel\n                </button>\n                <button\n                  onClick={async () => {\n                    await onClearHistory();\n                    setShowClearConfirm(false);\n                  }}\n                  className=\"flex-1 bg-rose-600 hover:bg-rose-500 text-white font-bold py-2 rounded transition-colors\"\n                >\n                  Clear core\n                </button>\n              </div>\n            </motion.div>\n          </motion.div>\n        )}\n      </AnimatePresence>\n\n    </div>"
      }
      num_matches: 1
    }
  }
}
